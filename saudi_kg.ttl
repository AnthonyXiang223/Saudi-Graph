    saudi:hasDAG "{\"op\": \"var\", \"name\": \"omega500_raw\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/qmax_2m> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "qmax_2m" ;
    qudt:unit qudt:KiloGM-PER-KiloGM ;
    rdfs:comment "日最大2米比湿，湿热上限" ;
