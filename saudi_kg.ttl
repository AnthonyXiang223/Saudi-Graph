hip1:BI0027 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0027 ;
    rdfs:label "Zoonotic Diseases" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC09 ],
        hip1:SpecificHazard ;
    skos:definition "Zoonotic diseases are a group of communicable diseases that are transmissible from vertebrate animals to humans through direct contact or through food, water, and the environment (WHO, no date)." .

hip1:BI0028 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0028 ;
    rdfs:label "Diarrhoeal Diseases (Human)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC09 ],
        hip1:SpecificHazard ;
    hip1:definedAs hip1:definition.BI0028 ;
    hip1:identifier "BI0028" .

hip1:BI0029 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0029 ;
    rdfs:label "Prion Diseases" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
