    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC04 ],
        hip1:SpecificHazard ;
    hip1:identifier "BI0007" ;
    hip1:synonym "Animal-human interaction",
        "Human-wildlife interaction" .

hip1:BI0008 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0008 ;
    rdfs:label "Biological Agents" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
