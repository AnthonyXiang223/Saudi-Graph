    hip1:definedAs hip1:definition.TL0006 ;
    hip1:identifier "TL0006" .

hip1:TL0007 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0007 ;
    rdfs:label "Structural Failure" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC38 ],
        hip1:SpecificHazard ;
    skos:definition "Structural failure corresponds to the exceedance of ultimate limit state in many of the load-carrying elements, which compromise the structural stability of the building (Rossetto, 2013)." .

hip1:TL0008 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0008 ;
    rdfs:label "Bridge Failure" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC38 ],
        hip1:SpecificHazard ;
    hip1:definedAs hip1:definition.TL0008 ;
    hip1:identifier "TL0008" ;
    hip1:synonym "Bridge collapse" .

hip1:TL0009 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0009 ;
    rdfs:label "Dam Failure" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC38 ],
        hip1:SpecificHazard ;
    hip1:definedAs hip1:definition.TL0009 ;
    hip1:identifier "TL0009" ;
    hip1:synonym "Dam breach",
        "Dam break",
        "Dam burst",
        "Outburst" .

hip1:TL0010 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0010 ;
    rdfs:label "Supply Chain Failure" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC38 ],
        hip1:SpecificHazard ;
    skos:definition "Supply chain failure refers to an event in the supply chain that disrupts the flow of materials on their journey from initial suppliers through to final customers (Walters, 2007)." .

hip1:TL0011 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0011 ;
    rdfs:label "Critical Infrastructure Failure" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC38 ],
        hip1:SpecificHazard ;
    hip1:definedAs hip1:definition.TL0011 ;
    hip1:identifier "TL0011" .

hip1:TL0012 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0012 ;
    rdfs:label "Nuclear Plant Failure" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC39 ],
        hip1:SpecificHazard ;
    skos:definition "Nuclear plant failure occurs when the accidental melting of the core of a nuclear reactor results in either the core to have a complete or partial collapse (adapted from USNRC, 1975)." .

hip1:TL0013 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0013 ;
    rdfs:label "Power Outage/ or Blackout" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC39 ],
        hip1:SpecificHazard ;
    skos:definition "In the electric power domain, especially in power transmission and distribution, a power outage usually refers to a partial or total loss of power supply to some end user (e.g., population, enterprises, critical systems). Triggering factors may include accidents, equipment breakdowns, failure of control mechanisms, targeted attacks (physical or cyber), organisational errors, and natural hazards (adapted from Pescaroli et al., 2017; UK Cabinet Office, 2017; EIS Council, 2019; and FEMA, 2018)." .

hip1:TL0014 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0014 ;
    rdfs:label "Emergency Telecommunications Failure" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC39 ],
        hip1:SpecificHazard .

hip1:TL0015 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0015 ;
    rdfs:label "Water Supply Failure" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC39 ],
        hip1:SpecificHazard ;
    skos:definition """Water supply failure is the physical shortage or scarcity in access of water supply due to the failure of institutions to ensure a regular supply or due to a lack of adequate infrastructure (adapted from UN-Water, no date).\r
\r
Alternative definition: Water supply systems are networks whose edges and nodes are pressure pipes and either pipe junctions, water sources or end-users. Water supply systems are designed to protect the customer from natural biological contamination, and the same systems have potential efficacy against deliberate biological and chemical contamination (adapted from Franchin and Cavalieri, 2013; and Jain et al., 2014).""" .

hip1:TL0016 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0016 ;
    rdfs:label "Radio and Other Telecommunication Failures" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC39 ],
        hip1:SpecificHazard ;
    skos:definition "Radio and other telecommunication failures can be said to occur when there is internal or external interruption of communications by either party that results in difficult to transport the message as it was intended (adapted from Dainty et al., 2007)." .

hip1:TL0017 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0017 ;
    rdfs:label "Misconfiguration of Software and Hardware" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC40 ],
        hip1:SpecificHazard ;
    skos:definition "Misconfiguration of software and hardware is the incorrect or suboptimal configuration of an information system or system component that may lead to vulnerabilities (NIST, no date)." .

hip1:TL0018 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0018 ;
    rdfs:label "Non-Conformity and Interoperability" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC40 ],
        hip1:SpecificHazard ;
    skos:definition """Conformity assessment: activity that provides demonstration that specified requirements relating to a product, process, system, person or body are fulfilled (NIST Information Technology Laboratory, no date).\r
\r
For the purposes of this standard, interoperability allows any government facility or information system, regardless of the personal Identity verification (PIV) Issuer, to verify a cardholder’s identity using the credentials on the PIV Card (NIST, no date).""" .

hip1:TL0019 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0019 ;
    rdfs:label "Malware" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:HC40 ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:TL ],
        hip1:SpecificHazard ;
    skos:definition "Malware is a summary term for different forms of malevolent software designed to infiltrate and infect computers, typically without the knowledge of the owner (ITU, 2008)." .

hip1:TL0020 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0020 ;
    rdfs:label "Data Breach" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC40 ],
        hip1:SpecificHazard ;
    hip1:definedAs hip1:definition.TL0020 ;
    hip1:identifier "TL0020" ;
    hip1:synonym "Data leak",
        "Data spill",
        "Intellectual data breach",
        "Security breach" .

hip1:TL0021 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0021 ;
    rdfs:label "Data Security-Related Hazards" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC40 ],
        hip1:SpecificHazard ;
    hip1:definedAs hip1:definition.TL0021 ;
    hip1:identifier "TL0021" ;
    hip1:synonym "Security incidents",
        "Security threats" .

hip1:TL0022 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0022 ;
    rdfs:label "Disrupt" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC40 ],
        hip1:SpecificHazard ;
    hip1:definedAs hip1:definition.TL0022 ;
    hip1:identifier "TL0022" ;
    hip1:synonym "Disruption tolerance",
        "Internet resilience",
        "Network security" .

hip1:TL0023 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0023 ;
    rdfs:label "Outage" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC40 ],
        hip1:SpecificHazard ;
    skos:definition "A cyber outage is the unavailability of a service or resource (ITU, 1996)." .

hip1:TL0024 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0024 ;
    rdfs:label "Personally Identifiable Information (PII) Breach" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC40 ],
        hip1:SpecificHazard ;
    skos:definition "A personally identifiable information (PII) breach is a situation where PII is processed in violation of one or more relevant PII protection requirements (ITU, 2018)." .

hip1:TL0025 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0025 ;
    rdfs:label "Internet of Things (IOT)-Related Hazards" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:HC40 ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:TL ],
        hip1:SpecificHazard ;
    skos:definition """The Internet of Things (IoT) is a global infrastructure for the information society, enabling advanced services by interconnecting (physical and virtual) things based on existing and evolving interoperable information and communication technologies (ITU, 2012).\r
\r
NOTE 1: Through the exploitation of identification, data capture, processing and communication capabilities, the IoT makes full use of things to offer services to all types of applications, while ensuring that security and privacy requirements are fulfilled.\r
\r
NOTE 2: From a broader perspective, the IoT can be perceived as a vision with technological and societal implications.\r
\r
The IoT is a relatively new technology that is a hazard if a data security or breach occurs.""" .

hip1:TL0026 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0026 ;
    rdfs:label "Cyberbullying" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC40 ],
        hip1:SpecificHazard ;
    hip1:definedAs hip1:definition.TL0026 ;
    hip1:identifier "TL0026" ;
    hip1:synonym "Cyber harassment",
        "Harassment online",
        "Online bullying",
        "Online harassment" .

hip1:TL0027 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0027 ;
    rdfs:label "Natech" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC41 ],
        hip1:SpecificHazard ;
    skos:definition "Natural hazard triggered technological accident (Showalter et al., 1994)." .

hip1:TL0028 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0028 ;
    rdfs:label "Pollution" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC41 ],
        hip1:SpecificHazard ;
    skos:definition """Pollution is defined as the presence of substances and/or heat in environmental media (air, water, land) whose nature, location, or quantity produces undesirable environmental effects (UN data, no date).\r
\r
Alternative definition: Pollution is defined as activity that generates pollutants (UN data, no date).""" .

hip1:TL0029 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0029 ;
    rdfs:label "Explosion" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC41 ],
        hip1:SpecificHazard .

hip1:TL0030 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0030 ;
    rdfs:label "Leaks and Spills" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC41 ],
        hip1:SpecificHazard ;
    skos:definition "A leak or a spill is an incident involving the uncontrolled release of a toxic substance, potentially resulting in harm to public health and the environment. Chemical incidents can occur as a result of natural events, or as a result of accidental or intentional events. These incidents can be sudden and acute or have a slow onset when there is a ‘silent’ release of a chemical. Chemical leaks and spills can range from small releases to full-scale major emergencies (adapted from WHO, 2020)." .

hip1:TL0031 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0031 ;
    rdfs:label "Soil Pollution" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC41 ],
        hip1:SpecificHazard ;
    skos:definition "Soil pollution refers to the presence of a chemical or substance out of place and/or present in a soil at higher than normal concentration that has adverse effects on any non-targeted organism (Rodríguez-Eugenio et al., 2018)." .

hip1:TL0032 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0032 ;
    rdfs:label "Industrial Fire" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:HC41 ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:TL ],
        hip1:SpecificHazard ;
    skos:definition "Fire related technological incidents can be defined as accidental or intentional events that result in the actual or potential exposure of responders and/or members of the public to a chemical hazard (adapted from WHO, no date)" .

hip1:TL0033 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0033 ;
    rdfs:label "Mining Hazards" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC41 ],
        hip1:SpecificHazard ;
    skos:definition "Mining hazards can be defined as having major environmental impacts including the production of waste, release of toxic and hazardous waste, air pollution and emissions, water pollution and depletion, and the loss of productive land and ecosystems (adapted from UNDP and UN Environment, 2018)." .

hip1:TL0034 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0034 ;
    rdfs:label "Safety Hazards Associated with Oil and Gas Extraction Activities" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC41 ],
        hip1:SpecificHazard ;
    skos:definition """Oil and gas extraction, and associated servicing activities involve many types of equipment and materials. Identifying and controlling hazards is critical to preventing injuries and deaths (US Department of Labor, no date).\r
\r
Alternative definition: For the purpose of the C155 - Occupational Safety and Health Convention, 1981 (No. 155) (ILO, 1981):\r
a) the term branches of economic activity covers all branches in which workers are employed, including the public service.\r
b) the term workers covers all employed persons, including public employees.\r
c) the term workplace covers all places where workers need to be or to go by reason of their work and which are under the direct or indirect control of the employer.\r
d) the term regulations covers all provisions given force of law by the competent authority or authorities.\r
e) the term health, in relation to work, indicates not merely the absence of disease or infirmity; it also includes the physical and mental elements affecting health which are directly related to safety and hygiene at work.""" .

hip1:TL0035 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0035 ;
    rdfs:label "Disaster Waste" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC42 ],
        hip1:SpecificHazard ;
    hip1:definedAs hip1:definition.TL0035 ;
    hip1:identifier "TL0035" .

hip1:TL0036 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0036 ;
    rdfs:label "Solid Waste" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC42 ],
        hip1:SpecificHazard ;
    skos:definition "Solid waste covers discarded materials that are no longer required by the owner or user. Solid waste includes materials that are in a solid or liquid state but excludes wastewater and small particulate matter released into the atmosphere (United Nations, 2014)." .

hip1:TL0037 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0037 ;
    rdfs:label "Wastewater" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC42 ],
        hip1:SpecificHazard ;
    skos:definition "Wastewater is regarded as a combination of one or more of the following materials: domestic effluent consisting of ‘blackwater’ (excreta, urine and faecal sludge, contaminants from pharmaceutical and personal care products) and ‘greywater’ (used water from washing and bathing); water from commercial establishments and institutions, including hospitals; industrial effluent, stormwater and other urban runoff; and agricultural, horticultural and aquaculture runoff (UN Water, 2017)." .

hip1:TL0038 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0038 ;
    rdfs:label "Hazardous Waste" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC42 ],
        hip1:SpecificHazard ;
    skos:definition "Hazardous waste is waste that has physical, chemical, or biological characteristics such that it requires special handling and disposal procedures to avoid negative health effects, adverse environmental effects or both (Joint UNEP/OCHA Environment Unit, 2011)." .

hip1:TL0039 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0039 ;
    rdfs:label "Plastic Waste" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC42 ],
        hip1:SpecificHazard ;
    skos:definition "Plastic is a generic term used in the case of polymeric material that may contain other substances to improve performance and/or reduce costs, with plastic waste almost exclusively comprising one non-halogenated polymer and waste substances or objects which are disposed of or are intended to be disposed of or are required to be disposed of by the provisions of national law (adapted from Basel Convention, 1989; and Basel Convention Secretariat, 2019)." .

hip1:TL0041 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0041 ;
    rdfs:label "Electronic Waste" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC42 ],
        hip1:SpecificHazard .

hip1:TL0042 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0042 ;
    rdfs:label "Healthcare Risk Waste" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC42 ],
        hip1:SpecificHazard ;
    skos:definition "Healthcare waste includes waste generated within healthcare facilities, research centres and laboratories related to medical procedures and medical equipment. It also includes waste originating from minor and scattered healthcare sources, including waste produced in the course of emergency medical treatment or health care undertaken in the home (e.g., home dialysis, self-administration of insulin, recuperative care) (WHO, 2014)." .

hip1:TL0043 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0043 ;
    rdfs:label "Landfilling" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC42 ],
        hip1:SpecificHazard ;
    skos:definition "Landfilling is the final placement of waste into or onto the land in a controlled way. The definition covers both landfilling at internal sites (i.e., where a generator of waste is carrying out its own waste disposal at the place of generation) and at external sites (United Nations, 2016)." .

hip1:TL0044 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0044 ;
    rdfs:label "Tailings" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC42 ],
        hip1:SpecificHazard ;
    skos:definition "Tailings are a common by-product of the mineral recovery process. They usually take the form of a liquid slurry made of fine mineral particles (created when mined ore is crushed, ground and processed) and water (ICMM, 2019)." .

hip1:TL0045 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0045 ;
    rdfs:label "Waste Treatment Lagoons" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC42 ],
        hip1:SpecificHazard ;
    skos:definition "Waste [treatment] lagoons can be defined as impoundments made by excavation or earth fill for biological treatment of animal and other agricultural waste (Spellman and Bieber, 2012)." .

hip1:TL0046 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0046 ;
    rdfs:label "Drain and Sewer Flooding" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC25 ],
        hip1:SpecificHazard ;
    hip1:definedAs hip1:definition.TL0046 ;
    hip1:identifier "TL0046" ;
    hip1:synonym "Drainage floods",
        "Pluvial flood",
        "Urban flooding" .

hip1:TL0047 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0047 ;
    rdfs:label "Reservoir Flooding" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC25 ],
        hip1:SpecificHazard ;
    skos:definition "A reservoir is an artificial lake where water is stored (National Geographic, 2020). Reservoir flooding occurs when excess rainfall causes the lake level to rise or flood water to spill downstream." .

hip1:TL0048 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0048 ;
    rdfs:label "Air Transportation Accident" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC43 ],
        hip1:SpecificHazard ;
    hip1:definedAs hip1:definition.TL0048 ;
    hip1:identifier "TL0048" .

hip1:TL0049 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0049 ;
    rdfs:label "Inland Water Ways" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC43 ],
        hip1:SpecificHazard ;
    skos:definition "An inland waterway transportation accident is an unwanted or unintended sudden event or a specific chain of such events occurring in connection with inland water vessel operations, which have harmful consequences (United Nations, European Union and the International Transport Forum at the OECD, 2019)." .

hip1:TL0050 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0050 ;
    rdfs:label "Marine Accident",
        "Marine Debris" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC43 ],
        hip1:SpecificHazard ;
    skos:definition "A marine accident is an event, or a sequence of events, that has resulted in any of the following occurring directly in connection with the normal operation of a marine vessel: the death of, or serious injury to, a person; the loss of a person from a ship; the loss, presumed loss or abandonment of a marine vessel; material damage to a marine vessel; the stranding or disabling of a marine vessel, or the involvement of a marine vessel in a collision; material damage to the marine infrastructures external to a vessel, that could seriously endanger the safety of the vessel or another vessel or an individual; and severe damage to the environment, or the potential for severe damage to the environment, brought about by the damage of a marine vessel (United Nations, European Union and the International Transport Forum at the OECD, 2019).",
        "Marine debris is any persistent, manufactured or processed solid material discarded, disposed of or abandoned in the marine and coastal environment. Marine litter consists of items that have been made or used by people and deliberately discarded into the sea or rivers or on beaches; brought indirectly to the sea with rivers, sewage, storm water or winds; or accidentally lost, including material lost at sea in bad weather (adapted from UN Environment, no date; and NOAA, no date)." .

hip1:TL0051 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0051 ;
    rdfs:label "Rail Accident" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC43 ],
        hip1:SpecificHazard ;
    skos:definition "A rail accident is an unwanted or unintended sudden event or a specific chain of such events (occurring during train operation) which has harmful consequences (United Nations, European Union and the International Transport Forum at the OECD, 2019)." .

hip1:TL0052 a owl:Class,
        owl:NamedIndividual,
        hip1:TL0052 ;
    rdfs:label "Road Traffic Accident" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:TL ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC43 ],
        hip1:SpecificHazard ;
    skos:definition "A road traffic accident is any accident involving at least one road vehicle in motion on a public road or private road to which the public has right of access, resulting in at least one injured or killed person (United Nations, European Union and the International Transport Forum at the OECD, 2019)." .

hip1:definition.BI0008 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Biological agents, according to the Convention on the Prohibition of the Development, Production and Stockpiling of Bacteriological (Biological) and Toxin Weapons and on their Destruction (1972), include germs, toxins and viruses that can sicken or kill people, livestock, or crops" ;
    hip1:definitionSource hip1:organization.unoda .

hip1:definition.BI0010 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://www.fao.org/fao-who-codexalimentarius/sh-proxy/en/?lnk=1&url=https%253A%252F%252Fworkspace.fao.org%252Fsites%252Fcodex%252FStandards%252FCXG%2B77-2011%252FCXG_077e.pdf" ;
    skos:definition "Antimicrobial resistance is the ability of a microorganism to multiply or persist in the presence of an increased level of an antimicrobial agent relative to the susceptible counterpart of the same species" ;
    hip1:definitionSource hip1:organization.fao,
        hip1:organization.who .

hip1:definition.BI0012 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://www.fao.org/3/i8656en/i8656en.pdf" ;
    skos:definition "A bacterial plant disease is the occurrence of plant diseases caused by bacterial microorganisms over large areas with significant impacts on crop and forest productivity or natural habitat" ;
    hip1:definitionSource hip1:organization.fao .

hip1:definition.BI0015 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://iris.who.int/bitstream/handle/10665/97503/9789241547536_eng.pdf?sequence=1",
        "https://www.cdc.gov/anthrax/index.html" ;
    skos:definition "Anthrax is a disease caused by the spore-forming bacteria Bacillus anthracis. Anthrax is primarily a disease of herbivorous animals, although all mammals, including humans can contract it. In humans, anthrax manifests itself in three distinct patterns (cutaneous, gastrointestinal, inhalational)" ;
    hip1:definitionSource hip1:organization.fao,
        hip1:organization.oie,
        hip1:organization.who .

hip1:definition.BI0016 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://www.who.int/news-room/commentaries/detail/transmission-of-sars-cov-2-implications-for-infection-prevention-precautions" ;
    skos:definition "Airborne transmission of infectious agents refers to the transmission of disease caused by dissemination of very small droplets that remain infectious when suspended in air over long distance and time" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.BI0017 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Blood-borne viruses are viruses transmitted by direct contact with infected blood or other body fluids" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.BI0025 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://www.who.int/news-room/fact-sheets/detail/antimicrobial-resistance" ;
    skos:definition "Antimicrobial resistant microorganisms are those microorganisms (such as bacteria, fungi, viruses, and parasites) that change when they are exposed to antimicrobial drugs (such as antibiotics, antifungals, antivirals, antimalarials, and anthelmintic). Microorganisms that develop antimicrobial resistance are sometimes referred to as ‘superbugs’. As a result, the medicines become ineffective and infections persist in the body, increasing the risk of spread to others" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.BI0026 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "Tomley, F.M. and M.W. Shirley, 2009. Livestock infectious diseases and zoonoses. Philosophical Transactions of the Royal Society of London B, 364:2637-2642.",
        "https://www.britannica.com/science/zoonotic-disease" ;
    skos:definition "Animal disease is an impairment of the normal state of an animal that interrupts or modifies its vital function. Infectious diseases of livestock and wildlife are a major threat to global animal health and welfare and their effective control is crucial for agronomic health, for safeguarding and securing national and international food supplies and for alleviating rural poverty in developing countries. This hazard information profile focusses on animal diseases not including zoonoses" .

hip1:definition.BI0028 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Diarrhoeal diseases are infectious diseases, contaminants and other causes of diarrhoea. Diarrhoea is defined as the passage of three or more loose or liquid stools per day, or more frequently than is normal for the individual (WHO, no date). This includes the three clinical types of diarrhoea: acute watery diarrhoea – lasts several hours or days, and includes cholera; acute bloody diarrhoea – also called dysentery; and persistent diarrhoea – lasts 14 days or longer" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.BI0033 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "COVID-19 is an infectious disease caused by the SARS Coronavirus 2 (SARS CoC2), a virus first identified in human populations in late 2019. Transmission occurs through droplets containing infectious virus, either by direct face to face contact (splash) generated by speaking, singing, coughing or sneezing; or by aerosolisation for up to 1 metre. Virus-containing aerosols that travel further than 1 metre are defined as airborne. The virus is thought to infect humans through the mucus membranes of the eyes, nose and mouth. Living virus has been isolated from faeces and urine but neither is thought to represent a major means of transmission. Fomites are thought to represent a low risk of transmission, but the risk has not yet been quantified. The risk of transmission is greatest in closed, poorly ventilated spaces where humans are in close proximity for ten to fifteen minutes and do not physically distance or wear a protective face covering" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.BI0034 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Cholera is an acute diarrhoeal infection caused by ingestion of food or water contaminated with the bacterium Vibrio cholerae. Cholera remains a global threat to public health" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.BI0035 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Cryptosporidium is a microscopic parasite that causes the watery diarrhoeal disease cryptosporidiosis" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.BI0042 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Avian influenza is an infectious disease of birds caused by type A influenza viruses of the Orthomyxoviridae family. Naturally occurring among wild bird populations, avian influenza viruses can infect domestic poultry and other bird species. Some avian influenza viruses can also infect mammals and those affecting humans are called zoonotic. A pandemic can occur when a novel zoonotic avian influenza virus spreads in human populations worldwide" ;
    hip1:definitionSource hip1:organization.fao,
        hip1:organization.oie,
        hip1:organization.who .

hip1:definition.BI0045 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Cysticercosis is a preventable intestinal infection in humans and animals caused by the tapeworm Taenia solium (pork tapeworm). Human cysticercosisi can result in devastating effects on human health resulting in neurocysticercosis with blindness, convulsions, and epileptic seizures, and can be fatal. It is estimated to affect between 2.56 and 8.30 million people, based on the range of epilepsy prevalence data available" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.BI0049 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Chikungunya is a mosquito-borne viral infection caused by the chikungunya virus. It causes fever and severe arthralgia (joint pain) which is often debilitating. The disease can be endemic and epidemic in countries" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.BI0051 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Diphtheria is a widespread severe infectious disease caused by the bacterium Corynebacterium diphtheriae and the toxin they produce. It is a potentially life-threatening, vaccine-preventable disease that primarily affects the throat and upper airways and has the potential for epidemics" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.BI0059 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Dengue is a mosquito-borne disease that is caused by a virus of the Flaviviridae family and transmitted by female mosquitoes mainly of the species Aedes aegypti and, to a lesser extent, A. albopictus" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.BI0061 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Crimean-Congo haemorrhagic fever (CCHF) is a tick-borne viral infection caused by the CCHF virus. It causes severe viral haemorrhagic fever outbreaks and epidemics" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.BI0070 a owl:NamedIndividual,
        hip1:Definition ;
    terms:date 2019 ;
    terms:references "https://www.fao.org/3/ca5987en/ca5987en.pdf" ;
    skos:definition "African swine fever is a devastating haemorrhagic viral disease of pigs, affecting domestic and wild pigs of all ages and both sexes" ;
    hip1:definitionSource hip1:organization.fao,
        hip1:organization.oie .

hip1:definition.BI0072 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Brucellosis is a bacterial disease caused by various Brucella species, which mainly infect cattle, swine, goats, sheep and dogs" ;
    hip1:definitionSource hip1:organization.fao,
        hip1:organization.oie,
        hip1:organization.who .

hip1:definition.BI0073 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Classical swine fever, also known as hog cholera, is a contagious viral disease of domestic and wild swine. It is caused by a virus of the genus Pestivirus of the family Flaviviridae" ;
    hip1:definitionSource hip1:organization.fao,
        hip1:organization.oie .

hip1:definition.BI0074 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Contagious bovine pleuropneumonia is an infectious and contagious respiratory disease of Bovidae caused by Mycoplasma mycoides subspecies mycoides SC (Mmm)" ;
    hip1:definitionSource hip1:organization.fao,
        hip1:organization.oie .

hip1:definition.BI0075 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Contagious caprine pleuropneumonia is a severe disease of goats caused by Mycoplasma capricolum subsp. capripneumonIae (Mccp). The acute form of the disease is characterised by unilateral serofibrinous pleuropneumonia with severe pleural fluid" ;
    hip1:definitionSource hip1:organization.fao,
        hip1:organization.oie .

hip1:definition.CH0001 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://www.gov.uk/government/publications/ammonia-properties-incident-management-and-toxicology",
        "https://www.inchem.org/documents/ehc/ehc/ehc54.htm#SectionNumber:10.4" ;
    skos:definition "Ammonia (NH3) is a colourless acrid-smelling reactive gas at ambient temperature and pressure and is considered a significant public health hazard" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.CH0002 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Carbon monoxide is a colourless, odourless gas that can be poisonous to humans and is considered a significant public health hazard" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.CH0003 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://iris.who.int/bitstream/handle/10665/329482/WHO-CED-PHE-EPE-19.4.1-eng.pdf?ua=1" ;
    skos:definition "Arsenic is a toxic heavy metal widely distributed throughout the Earth’s crust, generally as arsenic sulphide or as metal arsenates and arsenides. Human exposure to arsenic compounds represents a major public health concern as it has been associated with a range of acute and long-term adverse health effects and diseases" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.CH0013 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Dioxins and dioxin-like substances, including polychlorinated biphenyls (PCBs), polychlorinated dibenzo-p-dioxins (PCDDs) and polychlorinated dibenzofurans (PCDFs) are persistent organic pollutants (POPs) and are unwanted by-products of combustion and various industrial processes, such as chlorine bleaching of paper pulp and smelting. They can travel long distances from the source of emission, and bioaccumulate in food chains These substances represent a major public health concern. They have been associated with a range of acute and long-term adverse health effects and diseases" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.CH0016 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Chlorine is a reactive pale green gas with many uses including disinfection of water that is approximately three times heavier than air and has a characteristic odour similar to bleach. Most significant exposures to chlorine result from loss of containment of chlorine during storage and transport. Human exposure can result in symptoms ranging from mild irritation to rapid death related to pulmonary oedema. It is considered a significant public health hazard" .

hip1:definition.CH0018 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Benzene is a clear, colourless, highly flammable and volatile, liquid aromatic hydrocarbon (molecular formula C6H6) with a gasoline-like odour" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.CH0019 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Chemical agents or ‘chemical warfare agents’ (chemical weapons) are chemicals used to cause intentional death or harm through their toxic properties. Munitions, devices and other equipment specifically designed to weaponise toxic chemicals also fall under the definition of chemical weapons. The Chemical Weapons Convention (CWC) prohibition against the use of toxic chemicals and their precursors and also covers toxins of biological origin" .

hip1:definition.CH0020 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://www.who.int/teams/environment-climate-change-and-health/chemical-safety-and-health/health-impacts/chemicals/asbestos" ;
    skos:definition "Asbestos is the term for a group of naturally occurring minerals widely used historically in building materials and other products (WHO, no date). All types of asbestos cause lung cancer, mesothelioma, cancer of the larynx and ovary, and asbestosis (fibrosis of the lungs)" ;
    hip1:definitionSource hip1:organization.ipcs,
        hip1:organization.who .

hip1:definition.CH0021 a owl:NamedIndividual,
        hip1:Definition ;
    terms:date "2018"^^xsd:gYear ;
    terms:references "https://www.who.int/foodsafety/FSDigest_Aflatoxins_EN.pdf",
        "https://www.who.int/news-room/fact-sheets/detail/mycotoxins" ;
    skos:definition "Aflatoxins are mycotoxins – toxic compounds that are naturally produced by certain types of mould (fungi). Aflatoxins are among the most poisonous mycotoxins and are produced by certain moulds (Aspergillus flavus and A. parasiticus) that grow in soil, decaying vegetation, hay, and grains. Aflatoxins pose a serious health risk to humans and livestock" ;
    hip1:definitionSource hip1:organization.fao,
        hip1:organization.wmo .

hip1:definition.EN0002 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "Kibble, A. and R. Harrison, 2005. Point sources of air pollution. Occupational Medicine, 55:425-431.",
        "https://academic.oup.com/book/24607" ;
    skos:definition "A point source of air pollution is an identifiable stationary location or fixed facility from which air pollutants are released, which may be manmade or natural in origin" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.EN0003 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://www.who.int/news-room/fact-sheets/detail/ambient-(outdoor)-air-quality-and-health" ;
    skos:definition "Ambient (outdoor) air pollution is a leading environmental risk factor affecting urban and rural populations around the world, resulting in an estimated 4.2 million premature deaths in 2016" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.EN0008 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Biodiversity loss refers to the reduction of any aspect of biological diversity (i.e., diversity at the genetic, species and ecosystem levels) in a particular area through death (including extinction), destruction or manual removal; it can refer to many scales, from global extinctions to population extinctions, resulting in decreased total diversity at the same scale" ;
    hip1:definitionSource hip1:organization.ipbes .

hip1:definition.EN0009 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Deforestation is the conversion of forest to other land use independently of whether human-induced or not" ;
    hip1:definitionSource hip1:organization.fao .

hip1:definition.EN0014 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Desertification refers to land degradation in arid, semi-arid and dry subhumid areas resulting from various factors, including climatic variations and human activities" ;
    hip1:definitionSource hip1:organization.unccd .

hip1:definition.EN0017 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Corals are subject to ‘bleaching’ when the seawater temperature is too high: they lose the symbiotic algae that give coral its colour and part of its nutrients. Severe, prolonged or repeated bleaching can lead to the death of coral colonies" .

hip1:definition.EN0018 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Compressible soils include both compressive and collapsible soils. Compressive soils are soils that are prone to volumetric change when subject to mechanical loading (USDA, 1990:30). Collapsible soils are metastable in that they are prone to volumetric change (collapse) on wetting and loading" ;
    hip1:definitionSource hip1:organization.bgs .

hip1:definition.EN0020 a owl:NamedIndividual,
        hip1:Definition ;
    hip1:definitionSource hip1:organization.bgs ;
    hip1:synonym "Coastal erosion is the physical reduction of land mass at the coast that results from the interfacing of marine, fluvial and landsliding (driven by the interactions between groundwater and the soil or rock) processes with the coast" .

hip1:definition.ET0001 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://www.dictionary.com/browse/airburst" ;
    skos:definition "An airburst is defined as an explosion in the air, especially of a nuclear bomb or large meteorite" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.GH0010 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://www.bgs.ac.uk/discovering-geology/earth-hazards/volcanoes/volcanic-hazards/#tephraash" ;
    skos:definition "Tephra is a collective term for fragmented magma and old (i.e., preexisting) rocks ejected into the atmosphere from volcanic vents during an explosive eruption, irrespective of size, composition and shape (BGS, no date). The term ‘volcanic ash’ refers to the finest particles of tephra (less than 2 mm diameter)." ;
    hip1:definitionSource hip1:organization.gvm,
        hip1:organization.iavcei,
        hip1:organization.ivhhn .

hip1:definition.GH0011 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Ballistics comprise fragments of magma and old (i.e., pre-existing) rocks ejected during an explosive eruption at variable velocity and angle on cannon ball-like trajectories; they are not entrained within the volcanic plume and are dispersed in proximity to the vent (typically 5 km)" ;
    hip1:definitionSource hip1:organization.gvm,
        hip1:organization.iavcei,
        hip1:organization.ivhhn .

hip1:definition.GH0013 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Lahars are discrete, rapid, gravity-driven, water-saturated flows containing water and solid particles of volcanic rock, sediment, ice, wood, and other debris that originate at volcanoes" ;
    hip1:definitionSource hip1:organization.gvm,
        hip1:organization.iavcei,
        hip1:organization.ivhhn .

hip1:definition.GH0030 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://www.usgs.gov/special-topics/water-science-school/science/aquifers-and-groundwater?qt-science_center_objects=0#qt-science_center_objects" ;
    skos:definition "An aquifer is a water-bearing rock that readily transmits water to wells and springs. It can be recharged either naturally (precipitation including rainfall or snow) or artificially (e.g., pumped river recharge via wells). Failure or outage can be due to derogation, well failure or contamination" ;
    hip1:definitionSource hip1:organization.bgs .

hip1:definition.MH0001 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A downburst is a violent and damaging downdraught reaching the ground surface, associated with a severe thunderstorm" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0004 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Coastal flooding is most frequently the result of storm surges and high winds coinciding with high tides. The surge itself is the result of the raising of sea levels due to low atmospheric pressure. In particular configurations, such as major estuaries or confined sea areas, the piling up of water is amplified by a combination of the shallowing of the seabed and retarding of return flow" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0005 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Estuarine flooding is flooding over and near coastal areas caused by storm surges and high winds coincident with high tides, thereby obstructing the seaward river flow. Estuarine flooding can be caused by tsunamis in specific cases" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0006 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A flash flood is a flood of short duration with a relatively high peak discharge in which the time interval between the observable causative event and the flood is less than four to six hours" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0014 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Black carbon refers to the absorbing components of soot, often defined using elemental carbon and some condensed organics. Black carbon is an important part of the combustion product commonly referred to as soot. Black carbon in indoor environments is largely due to cooking with biofuels such as wood, dung and crop residue. Outdoors, it is due to fossil fuel combustion (diesel and coal), open biomass burning (associated with deforestation and crop residue burning), and cooking with biofuels" .

hip1:definition.MH0015 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A dust storm is an ensemble of particles of dust or sand energetically lifted to great heights by a strong and turbulent wind" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0016 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Fog is a suspension of very small, usually microscopic water droplets in the air, reducing visibility at the Earth’s surface" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0030 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A depression or cyclone is a region of the atmosphere in which the pressures are lower than those of the surrounding region at the same level" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0033 a owl:NamedIndividual,
        hip1:Definition ;
    terms:date "2012"^^xsd:gYear ;
    terms:references "https://www.wmo.int/%20pages/prog/hwrp/publications/international_glossary/385_IGH_2012.pdf" ;
    skos:definition "Acid rain is rain which in the course of its history has combined with chemical elements or pollutants in the atmosphere and reaches the Earth’s surface as a weak acid solution." ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0034 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A blizzard is a severe snow storm characterised by poor visibility, usually occurring at high-latitude and in mountainous regions" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0035 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A drought is a period of abnormally dry weather characterised by a prolonged deficiency of precipitation below a certain threshold over a large area and a period longer than a month" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0040 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A cold wave is a period of marked and unusual cold weather characterised by a sharp and significant drop in air temperatures near the surface (maximum, minimum and daily average) over a large area and persisting below certain thresholds for at least two consecutive days during the cold season" ;
    hip1:definitionSource hip1:organization.who,
        hip1:organization.wmo .

hip1:definition.MH0041 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A dzud (a Mongolian term that describes ‘severe winter conditions’’, sometimes spelled zud) is a cold-season disaster in which anomalous climatic (i.e., heavy snow and severe cold) and/or land-surface (snow/ ice cover and lack of pasture) conditions lead to reduced accessibility and/or availability of forage/pastures, and ultimately to high livestock mortality during winter–spring. Severe dzuds (high mortality) result from a combination of growing-season drought and severe weather" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0043 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A hoar frost is a deposit of ice produced by the deposition of water vapour from the surrounding air and is generally crystalline in appearance" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0044 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Freezing rain is rain where the temperature of the water droplets is below 0°C. Drops of supercooled rain may freeze on impact with the ground, in-flight aircraft or other objects" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0045 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Glaze is a smooth compact deposit of ice, generally transparent, formed by the freezing of super-cooled drizzle droplets or raindrops on objects with a surface temperature below or slightly above 0°C" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0046 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Ground frost is a covering of ice, in one of its many forms, produced by the sublimation of the water vapour on objects colder than 0°C (WMO, 1992). Ground frost occurs when the temperature of the upper layer of the soil is less than 0°C" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0050 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://library.wmo.int/doc_num.php?explnum_id=4712" ;
    skos:definition "An avalanche is a mass of snow and ice falling suddenly down a mountain slope and often taking with it earth, rocks and rubble of every description" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0053 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Derechos are fast-moving bands of thunderstorms with destructive winds. The winds can be as strong as those found in hurricanes or even tornadoes. Unlike hurricanes and tornadoes, these winds follow straight lines" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0054 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A gale is wind with a speed of between 34 and 40 knots (62–74 km/h, 32–38 mph). Also known as Beaufort scale wind force 8" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.SO0003 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition """‘Civil unrest’ is an umbrella term for a wide spectrum of phenomena, and although there is no commonly agreed United Nations definition the term is used widely among United Nations agencies, funds and programmes, particularly to describe violent and non-violent group acts.\r
\r
A suggested definition for ‘civil unrest’ is as follows: a term that includes limited political violence (such as acts of ‘terrorism’, individual assassinations, etc.), sporadic violent collective action (such as riots), or nonviolent and mildly violent collective action (such as protests, demonstrations, etc.) – all of which tend to take place in times of peace""" .

hip1:definition.TL0005 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Building collapse is the failure of load-bearing structural elements, causing a building to fall or fail catastrophically / catastrophic failure" ;
    hip1:definitionSource hip1:organization.usdol .

hip1:definition.TL0006 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A building high-rise cladding fire hazard occurs when combustible materials such as cladding on a high-rise building greatly increases risk in the event of a fire and can have a catastrophic outcome" .

hip1:definition.TL0008 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Bridge failure is the inability of a bridge, or its components, to perform as specified by its design and construction requirements (Wardhana and Hadipriono, 2003). Note: This definition includes bridges that have totally collapsed, partially collapsed and those that experienced distress, such as, exhibiting excessive deformation." .

hip1:definition.TL0009 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Dam failure is the collapse or movement of part of a dam or its foundation, such that the dam cannot retain water. In general, a failure results in a release of large quantities of water imposing risks on the people or property downstream" ;
    hip1:definitionSource hip1:organization.icold .

hip1:definition.TL0011 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Critical Infrastructure failure is defined as the failure in one or more of the physical structures, facilities, networks and other assets which provide services that are essential to the social and economic functioning of a community or society" ;
    hip1:definitionSource hip1:organization.unga .

hip1:definition.TL0020 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A data breach is a compromise of security that leads to the accidental or unlawful destruction, loss, alteration, unauthorised disclosure of, or access to protected data transmitted, stored, or otherwise processed" ;
    hip1:definitionSource hip1:organization.itu .

hip1:definition.TL0021 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Data security is related to the preservation of data to guarantee availability, confidentiality and data integrity. Data security-related hazards include risks arising from increased system complexity because this provides opportunities for malicious cyberattacks and data loss in the case of serious incidents, including natural disasters" ;
    hip1:definitionSource hip1:organization.itu .

hip1:definition.TL0022 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A service procedure is disrupted by another service if the second service results in service primitives of the first service not being used as specified for the procedure of the first service" ;
    hip1:definitionSource hip1:organization.itu .

hip1:definition.TL0026 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Cyberbullying is bullying that takes place using digital devices such as cell/mobile phones, computers, and tablets. Cyberbullying can occur through SMS, e-mail, apps, social media, forums, or gaming when people view, participate in, or share content. Cyberbullying includes the deliberate sending, posting, or sharing of negative, harmful, false, or mean content about someone else. It can include sharing personal or private information about someone else causing embarrassment or humiliation. Some cyberbullying may also be unlawful or criminal behaviour" ;
    hip1:definitionSource hip1:organization.itu .

hip1:definition.TL0035 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Disaster waste is the waste generated by the impact of a disaster, both as a direct effect of the disaster as well as in the post-disaster phase as a result of poor waste management" .

hip1:definition.TL0046 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Drain and sewer flooding is said to occur when sewage or foul water leaks from the sewerage system (through pipes, drains or manholes) or floods up through toilets, sinks or showers inside a building" .

hip1:definition.TL0048 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://unece.org/fileadmin/DAM/trans/main/wp6/pdfdocs/Glossary_for_Transport_Statistics_EN.pdf" ;
    skos:definition "An air transportation accident is defined as an occurrence associated with the operation of an aircraft which takes place between the time any person boards the aircraft with the intention of flight until such time as all such persons have disembarked, in which one of the following applies: a person is fatally or seriously injured, the aircraft sustains damage or structural failure, and the aircraft is missing or is completely inaccessible" ;
    hip1:definitionSource hip1:organization.icao,
        hip1:organization.unece .

hip1:narrower a owl:ObjectProperty ;
    rdfs:label "narrower" ;
    rdfs:subPropertyOf skos:narrower .

