        hip1:SpecificHazard ;
    hip1:identifier "BI0019" .

hip1:BI0020 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0020 ;
    rdfs:label "Sexually Transmitted Diseases (Human)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC09 ],
        hip1:SpecificHazard ;
    hip1:identifier "BI0020" ;
    hip1:synonym "STIs",
        "Sexually transmitted infections" .

hip1:BI0021 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0021 ;
    rdfs:label "Neglected Tropical Diseases (Human)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC09 ],
        hip1:SpecificHazard ;
    hip1:identifier "BI0021" .

hip1:BI0022 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0022 ;
    rdfs:label "Vaccine-Preventable Diseases" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC09 ],
        hip1:SpecificHazard ;
    skos:definition "Vaccine preventable diseases are those infectious diseases that can be prevented by vaccination (WHO, 2012)." .

hip1:BI0023 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0023 ;
    rdfs:label "Vector Borne Diseases (VBD) (Human)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC09 ],
        hip1:SpecificHazard ;
    skos:definition "Vector borne diseases encompass a variety of illnesses that are caused via the spread of pathogens by living organisms known as vectors. These infectious diseases can be transmitted via vectors among humans (e.g., malaria, dengue), among animals (e.g., African swine fever, East Coast fever), or from animals to humans (e.g., Nipah virus disease). Many of these vectors are bloodsucking insects, and mosquitoes are the bestknown disease vector. Other vectors include ticks, flies, sandflies, fleas, triatomine bugs and some species of freshwater aquatic snails (adapted from OIE, 2019; WHO, 2020)." .

hip1:BI0024 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0024 ;
    rdfs:label "Viral Haemorrhagic Fevers (Human)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC09 ],
        hip1:SpecificHazard ;
    skos:definition "Viral haemorrhagic fever is a general term for severe illnesses,sometimes associated with bleeding, that may be caused by a number of viruses. The term is usually applied to diseases caused by viruses that belong to the Arenaviridae, Bunyaviridae, Filoviridae and Flaviviridae families (WHO, no date)." .

hip1:BI0025 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0025 ;
    rdfs:label "Antimicrobial Resistant Microorganisms" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC09 ],
        hip1:SpecificHazard ;
    hip1:definedAs hip1:definition.BI0025 ;
    hip1:identifier "BI0025" ;
    hip1:synonym "Superbugs" .

hip1:BI0026 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0026 ;
    rdfs:label "Animal Diseases (Not Zoonoses)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC09 ],
