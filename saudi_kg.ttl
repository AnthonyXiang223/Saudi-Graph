    hip1:definedAs hip1:definition.BI0010 ;
    hip1:identifier "BI0010" .

hip1:BI0011 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0011 ;
    rdfs:label "Foodborne Microbial Hazards (including human enteric virus and foodborne parasite)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC07 ],
        hip1:SpecificHazard ;
    hip1:identifier "BI0011" .

hip1:BI0012 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0012 ;
    rdfs:label "Bacterial Plant Disease" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC08 ],
        hip1:SpecificHazard ;
    hip1:definedAs hip1:definition.BI0012 ;
    hip1:identifier "BI0012" .

hip1:BI0013 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0013 ;
    rdfs:label "Fungal Plant Disease" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC08 ],
        hip1:SpecificHazard ;
    hip1:identifier "BI0013" .

hip1:BI0014 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0014 ;
    rdfs:label "Viral, Mycoplasma and Viroid Plant Disease Epidemics" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC08 ],
        hip1:SpecificHazard ;
    skos:definition "Viral, mycoplasma and viroid plant disease epidemics are the occurrence of plant diseases caused by viruses, mycoplasma (syn. phytoplasma, mycoplasma-like organisms ) and viroids over large areas with significant impact on crop productivity or natural habitats (adapted from Nakashima and Murata, 1993; Hammond and Owens, 2006; FAO and IPPC, 2016; Rubio et al., 2020)." .

hip1:BI0015 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0015 ;
    rdfs:label "Anthrax" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC09 ],
        hip1:SpecificHazard ;
    hip1:definedAs hip1:definition.BI0015 ;
    hip1:identifier "BI0015" .

hip1:BI0016 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0016 ;
    rdfs:label "Airborne Diseases" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC09 ],
        hip1:SpecificHazard ;
    hip1:definedAs hip1:definition.BI0016 ;
    hip1:identifier "BI0016" .

hip1:BI0017 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0017 ;
    rdfs:label "Blood Borne Viruses" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC09 ],
        hip1:SpecificHazard ;
    hip1:definedAs hip1:definition.BI0017 ;
    hip1:identifier "BI0017" .

hip1:BI0018 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0018 ;
    rdfs:label "Waterborne Diseases" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC09 ],
        hip1:SpecificHazard ;
    skos:definition "Waterborne diseases are those diseases that are transmitted by ingestion of contaminated water (WHO,2012)." .

hip1:BI0019 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0019 ;
    rdfs:label "Foodborne Diseases" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
