hip1: a owl:Ontology ;
    rdfs:label "UNDRR Hazard Information Profile Classification prepared by UNDRR/ISC" ;
    terms:contributor "Shirly Stephen, Mark Schildhauer, Krysztof Janowicz, Pascal Hitzler"@en ;
    terms:created "04-24-2024" ;
    terms:description """Source documentation:\r
1. https://www.undrr.org/publication/hazard-information-profiles-supplement-undrr-isc-hazard-definition-classification\r
2. https://www.undrr.org/publication/hazard-definition-and-classification-review""",
        """The Sendai Framework for Disaster Risk Reduction 2015–2030 (‘the Sendai Framework’) was one of three landmark agreements adopted by the United Nations in 2015. The other two being the Sustainable Development Goals of Agenda 2030 and the Paris Agreement on Climate Change.\r
\r
The UNDRR/ISC Sendai Hazard Definition and Classification Review Technical Report supports all three by providing a common set of hazard definitions for monitoring and reviewing implementation which calls for “a data revolution, rigorous accountability mechanisms and renewed global partnerships”.""" ;
    terms:title "UNDRR Hazard Information Profiles" .

hip1:ScientificDescription a owl:Class ;
    rdfs:subClassOf hip1:MetadataElement .

hip1:coordinationOrganization a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:hadPrimarySource .

hip1:definedAs a owl:ObjectProperty ;
    rdfs:label "defined as" .

hip1:definition.BI0001 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Harmful algal blooms result from noxious and/or toxic algae that cause direct and indirect negative impacts on aquatic ecosystems, coastal resources, and human health" .

hip1:definition.BI0002 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "An insect pest infestation is a recently detected insect pest population, including an incursion, or a sudden significant increase of an established insect, disease agents or weed population in an area leading to damage to plants in production fields, forests or natural habitats and causing substantial damage to productivity, biodiversity or natural resources" .

hip1:definition.BI0003 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Widespread and heavy infestations of crops and natural vegetation by locusts causing significant threats to food security, livelihoods and natural habitats in multiple regions" .

hip1:definition.BI0004 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "An invasive weed is an alien species that by its establishment or spread has become injurious to plants, or that by risk analysis is shown to be potentially injurious to plants" .

hip1:definition.BI0005 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "‘Invasive species’, also known as ‘alien invasive species’, are species whose introduction, establishment and spread into new areas threaten ecosystems, habitats or other species and cause social, economic or environmental harm, or harm to human health" .

hip1:definition.BI0006 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A snake envenomation is a potentially life-threatening disease caused by toxins in the bite of a venomous snake. Envenoming can also be caused by having venom sprayed into the eyes by certain species of snake that have the ability to spit venom as a defence measure" .

hip1:definition.BI0007 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Human-wildlife conflict is defined as struggles that emerge when the presence or behaviour of wildlife poses an actual or perceived, direct and recurring threat to human interests or needs, leading to disagreements between groups of people and negative impacts on people and/or wildlife" .

hip1:definition.BI0009 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "The term ‘suicide cluster’ describes a situation in which more suicides than expected occur in terms of time, place, or both. It is difficult to precisely define a cluster. A suicide cluster usually includes three or more deaths; however, two suicides occurring in a specific community or setting (for example a school) in a short time period should also be taken very seriously in terms of possible links and impacts (even if the deaths are apparently unconnected), particularly in the case of young people" .

hip1:definition.BI0011 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition """Foodborne microbial hazards include (but are not limited to) pathogenic bacteria, viruses, algae, protozoa, fungi, parasites, prions, toxins and other harmful metabolites of microbial origin (FAO and WHO, 2007).\r
\r
A human enteric virus is a virus that replicates in the gastro-intestinal tract or in the liver and is excreted in faeces and/or vomitus from humans. It is transmitted mainly by the faecal-oral route and is infectious to humans (FAO and WHO, 2012).\r
\r
A foodborne parasite is any parasite that can be transmitted to humans by ingesting food (FAO and WHO, 2016).""" .

hip1:definition.BI0013 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Fungal plant disease is the occurrence of plant diseases caused by fungal agents over large areas with significant impact on crop productivity or natural habitats" .

hip1:definition.BI0019 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Foodborne diseases are transmitted by consumption of contaminated biological food and drink (WHO, 2012). These diseases are caused by eating food contaminated with bacteria, viruses, parasites or chemical substances" .

hip1:definition.BI0020 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Sexually transmitted diseases are infections transmitted from an infected person to an uninfected person through sexual contact" .

hip1:definition.BI0021 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Neglected tropical diseases (NTDs) are a diverse group of communicable diseases caused by bacteria, viruses or parasites that prevail in tropical and subtropical conditions (WHO, no date). Twenty diseases and disease groups are addressed in the global roadmap for NTDs 2021–2030" .

hip1:definition.BI0029 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Prion diseases are a family of rare progressive neurodegenerative disorders that affect both humans and animals" .

hip1:definition.BI0030 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Hepatitis B is a vaccine-preventable disease, that is endemic and epidemic worldwide, and caused by the Hepatitis B virus (HBV). HBV can cause both acute and chronic liver disease. Chronic infection puts people at high risk of death from cirrhosis and liver cancer" .

hip1:definition.BI0031 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Hepatitis C is a blood-borne liver disease caused by the hepatitis C virus: the virus can cause both acute and chronic hepatitis, ranging in severity from a mild illness lasting a few weeks to a serious, lifelong illness including liver cirrhosis and liver cancer. Hepatitis C is endemic and epidemic worldwide" .

hip1:definition.BI0032 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "The human immunodeficiency virus (HIV) is a viral sexually transmitted and blood-borne infection which targets the immune system, weakening people’s defences against opportunistic infections and some types of cancer. The most advanced stage of HIV infection is acquired immunodeficiency syndrome (AIDS), which can take from 2 to 15 years to develop if not treated, depending on the individual. AIDS is defined by the development of certain cancers, infections or other severe clinical manifestations" .

hip1:definition.BI0036 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Paratyphoid fever is a systemic disease caused by the bacterium Salmonella Paratyphi usually through ingestion of contaminated food or water" .

hip1:definition.BI0038 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Hepatitis A is an acute vaccine-preventable viral liver disease caused by the hepatitis A virus. The infection can cause mild to severe illness and is epidemic prone" .

hip1:definition.BI0039 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Escherichia coli (E. coli) is a bacterium commonly found in the gut. Some strains can cause serious food poisoning, leading to diarrhoea and sometimes to life-threatening complications including haemolytic uraemic syndrome" .

hip1:definition.BI0040 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Listeriosis is a foodborne infection caused by the bacterium Listeria monocytogenes which can be invasive (the more serious form of the disease) or non-invasive (the milder form of the disease). Listeriosis outbreaks occur in all countries and can be a significant public health concern" .

hip1:definition.BI0041 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Shigellosis is an acute invasive enteric infection caused by bacteria belonging to genus Shigella" .

hip1:definition.BI0043 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "An influenza pandemic is the worldwide spread of a new influenza virus to which there is little or no pre-existing immunity in the human population" .

hip1:definition.BI0044 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Seasonal influenza is an acute respiratory infection caused by influenza viruses which circulate in all parts of the world" .

hip1:definition.BI0046 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Leptospirosis is an infectious disease caused by pathogenic Spirochaetes of the genus Leptospira. These bacteria called leptospires affect both humans and animals. Humans become infected through direct contact with the urine of infected animals or with a urinecontaminated environment. It is a zoonosis. Human-to-human transmission occurs only very rarely" .

hip1:definition.BI0047 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Plague is an acute febrile infectious disease caused by the zoonotic bacteria Yersinia pestis" .

hip1:definition.BI0048 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Leprosy is a curable infectious disease, endemic in many countries, caused by the bacterium Mycobacterium leprae (M. leprae). It mainly affects the skin, peripheral nerves, mucosa of the upper respiratory tract and eyes. Untreated, it can lead to permanent disability" .

hip1:definition.BI0052 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Measles is a highly contagious, serious disease caused by a virus from the paramyxovirus family. Transmission occurs through direct contact, droplet spread, and airborne spread. The virus initially infects the respiratory tract, then spreads throughout the body" .

hip1:definition.BI0053 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Meningococcal meningitis is a bacterial form of meningitis, a serious infection of the thin lining that surrounds the brain and spinal cord, that is caused by the bacterium Neisseria meningitidis. Meningococcal meningitis has the potential to cause large-scale epidemics and is observed worldwide" .

hip1:definition.BI0054 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Pertussis is a highly contagious disease of the respiratory tract caused by the bacterium Bordetella pertussis" .

hip1:definition.BI0055 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Polio (human) is a highly infectious viral disease which mainly affects young children" .

hip1:definition.BI0056 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Smallpox is an acute contagious disease caused by the variola virus" .

hip1:definition.BI0060 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Malaria is a life-threatening disease caused by parasites that are transmitted to people through the bites of infected female Anopheles mosquitoes. It is preventable and curable. In 2018, there were an estimated 228 million cases of malaria worldwide and the estimated number of malaria deaths stood at 405,000" .

hip1:definition.BI0062 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Ebola virus disease (EVD) is a rare but severe zoonotic viral infectious disease caused by the Ebola virus. It can lead to haemorrhagic fever and is often fatal in humans. EVD can trigger epidemics with high casefatality rates" .

hip1:definition.BI0063 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Lassa fever is a zoonotic disease associated with acute and potentially fatal haemorrhagic illness caused by Lassa virus. It is associated with epidemics particularly where it is endemic in Benin, Ghana, Guinea, Liberia, Mali, Sierra Leone, and Nigeria" .

hip1:definition.BI0065 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Middle East respiratory syndrome (MERS) is a viral respiratory disease caused by MERS-Corona Virus (MERS-CoV)" .

hip1:definition.BI0066 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Monkeypox is a viral zoonotic disease that has symptoms similar to those of smallpox" .

hip1:definition.BI0067 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Rabies is a vaccine preventable zoonotic disease causing acute encephalitis which can progress towards coma and death typically within 7 to 10 days of the first signs if no intensive care is instituted. It is a disease of public health concern" .

hip1:definition.BI0068 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Severe acute respiratory syndrome (SARS) is a viral respiratory illness caused by a coronavirus called SARS-associated coronavirus (SARSCoV)" .

hip1:definition.BI0069 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Rotaviruses are the most common cause of severe diarrhoeal disease in young children throughout the world. According to WHO estimates in 2013 about 215,000 children aged under 5 years die each year from vaccine-preventable rotavirus infections; the vast majority of these children live in low-income countries" .

hip1:definition.BI0076 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Foot-and-mouth disease is caused by a virus of the family Picornaviridae, genus Aphthovirus. It is a highly contagious and economically important disease of cloven-hoofed domestic animals (cattle, buffaloes, pigs, sheep, goats) and wild animals" .

hip1:definition.BI0077 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Lumpy skin disease is a vector-borne pox disease of domestic cattle and Asian water buffalo and is characterised by the appearance of skin nodules on all body surface including the udder" .

hip1:definition.BI0078 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "New World screwworms are a type of blow fly larvae (maggots) that can infest livestock and other warm blooded animals, including people. They most often enter an animal through an open wound and feed on the animal’s living flesh. If not treated, infestations can be fatal" .

hip1:definition.BI0079 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Newcastle disease is an infectious disease of birds caused by Newcastle disease virus, of the Paramyxovirdae family. The disease is seen mainly in chickens, but many bird species and even reptiles and mammals are susceptible to infection" .

hip1:definition.BI0080 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Peste des petits ruminants is a highly contagious and devastating disease of goats and sheep. The causative agent, Peste des petits ruminants virus is a member of the genus Morbillivirus, Family Paramyxoviridae and Order Mononegavirales" .

hip1:definition.BI0081 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Q fever is a widespread zoonosis caused by the bacterium Coxiella burnetii. The respiratory tract is the most common route of infection, which occurs by inhalation of contaminated dust and spray shed from infected animals. Livestock, more specifically dairy goats and cows are considered as the major ‘source’ for human infections; dairy products from infected goats or cows are also an important source of infection" .

hip1:definition.BI0082 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Rift Valley fever (RVF) is an acute haemorrhagic viral disease, affecting small and large ruminants and camels. RVF virus is a member of the Phlebovirus genus. The disease causes high mortality especially in new borne and mass abortions in pregnant animals. Humans become infected from contact with tissues/blood of infected animals including abortive material and through mosquito bites. Disease in humans presents as influenza like illness, haemorrhagic fever, encephalitis and occasionally death" .

hip1:definition.BI0085 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Rinderpest was a disease caused by paramyxovirus in the genus Morbillivirus. It was most commonly observed in domestic cattle and buffaloes. The last confirmed outbreak of rinderpest was in 2001 and the disease was declared to have been eradicated globally in 2011 by the Food and Agriculture Organization of the United Nations (FAO) and the World Organisation for Animal Health (OIE). Rinderpest was a highly contagious viral disease of animals that, throughout history, has resulted in the mortality of hundreds of millions of livestock and has caused significant disruption and damage to agricultural supply chains throughout the world. Rinderpest is the first animal disease eradicated worldwide. The last confirmed outbreak of rinderpest was in 2001. Rinderpest was declared as eradicated by 2011. The Rinderpest Secretariat (FAO and OIE joint activity) is engaged in safeguarding the global freedom, similar to what has been done for smallpox by the World Health Organization" .

hip1:definition.BI0087 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Shrimp acute hepatopancreatic necrosis disease (AHPND) is caused by virulent strains of Vibrio parahaemolyticus and related Vibrio species. AHPND-associated mortalities occur early in the production cycle, usually within 30 to 35 days of stocking, and because of this AHPND was initially referred to as early mortality syndrome" .

hip1:definition.BI0088 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "There are a number of causal agents recognised for oyster diseases. Examples of major oyster diseases and their causal protozoan agents are: bonamiosis (Bonamia exitiosa, B. ostreae); marteiliosis (Marteilia refringens); perkinsosis (Perkinsus marinus, P. olseni). These oyster diseases are notifiable OIE-listed diseases and occur worldwide" .

hip1:definition.CH0005 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Lead is a naturally occurring highly toxic heavy metal. Its widespread use has caused extensive environmental contamination and health problems in many parts of the world. It is a cumulative toxicant that affects multiple body systems, including the neurological, haematological, gastrointestinal, cardiovascular and renal systems. Children are particularly vulnerable to the neurotoxic effects of lead, and even relatively low levels of exposure can cause serious and, in some cases, irreversible neurological damage (WHO, 2010)." ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.CH0006 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Mercury is a naturally occurring element that is found in air, water and soil. Exposure to mercury – even small amounts – may cause serious health problems and is a threat to the development of the foetus in utero and for children early in life (WHO, 2017)." ;
    hip1:definitionSource hip1:organization.fao,
        hip1:organization.who .

hip1:definition.CH0007 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A contaminant in food and feed is defined as any substance not intentionally added to food or feed for food-producing animals, which is present in such food or feed as a result of the production (including operations carried out in crop husbandry, animal husbandry and veterinary medicine), manufacture, processing, preparation, treatment, packing, packaging, transport or storage, or as a result of environmental contamination. Note: The term includes toxins, such as moulds, but does not include insect fragments, rodent hairs and other extraneous matter (FAO and WHO, 2019)." ;
    hip1:definitionSource hip1:organization.fao,
        hip1:organization.who .

hip1:definition.CH0008 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://www.unep.org/explore-topics/chemicals-waste/what-we-do/emerging-issues/highly-hazardous-pesticides-hhps" ;
    skos:definition """Pesticide means any substance, or mixture of substances of chemical or biological ingredients intended for repelling, destroying or controlling any pest, or regulating plant growth. Pesticides are inherently toxic, and among them, a small number of Highly Hazardous Pesticides, cause disproportionate harm to the environment and human health. The Food and Agriculture Organization (FAO) and the World Health Organization (WHO) Guidelines on Highly Hazardous pesticides (UNEP, 2021) adopted the following definition:\r
\r
“Highly Hazardous Pesticides means pesticides that are acknowledged to present particularly high levels of acute or chronic hazards to health or environment according to internationally accepted classification systems such as WHO or Global Harmonized System (GHS) or their listing in relevant binding international agreements or conventions. In addition, pesticides that appear to cause severe or irreversible harm to health or the environment under conditions of use in a country may be considered to be and treated as highly hazardous.”""" ;
    hip1:definitionSource hip1:organization.fao,
        hip1:organization.who .

hip1:definition.CH0009 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Pesticide residue means any specified substance in food, agricultural commodities, or animal feed resulting from the use of a pesticide. The term includes any derivatives of a pesticide, such as conversion products, metabolites, reaction products, and impurities considered to be of toxicological significance (FAO and WHO, no date, 2019)." ;
    hip1:definitionSource hip1:organization.fao,
        hip1:organization.who .

hip1:definition.CH0010 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Hazardous pesticide contamination in soils often results from improper storage of (obsolete) agrochemicals, as a result of which pesticides are spilled in the surroundings of the storage site, where they seep into the soil or are dispersed by wind. In some cases, pesticide spillage has been ongoing for many years. Such spillage may cause serious soil or groundwater contamination. In addition, highly toxic and persistent compounds have been used in agriculture for decades to control pests and diseases, which are proven to cause harm to non-target species. Although international agreements are put in place to regulate the production and use of those highly toxic and persistent compounds they will still remain in soils for several more decades. Moreover, in some countries, the international agreements are not yet being implemented or fully implemented, and therefore toxic pesticides are still being used. When soil and groundwater are contaminated, crops, livestock and drinking water may become affected and, when they are consumed by people, health risks may occur (FAO, 2000)." ;
    hip1:definitionSource hip1:organization.fao .

hip1:definition.CH0011 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://www.cdc.gov/nceh/tracking/topics/PesticideExposure.htm" ;
    skos:definition "Insecticides are chemicals used to control insects by killing them (CDC, 2019)." ;
    hip1:definitionSource hip1:organization.cdc .

hip1:definition.CH0014 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Microplastics are small plastic pieces less than five millimetres in length which can be harmful to the environment especially marine life. They originate from a variety of sources, including larger plastic debris that degrades into progressively smaller pieces (adapted from UNEP, 2016 and NOAA, no date)." .

hip1:definition.CH0015 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Phosphine (PH₃) is a colourless, flammable, and explosive gas at room temperature. The major uses of phosphine are as a rodenticide and fumigant for agricultural products and in the manufacture of semiconductors for the electronics industry. Exposure to low doses causes non-specific symptoms, such as nausea, vomiting, stomach pain, diarrhoea, thirst, muscle pain, difficulty breathing and fluid in the lungs. Exposure to higher doses may cause more severe effects, even death (adapted from PHE, 2017 and CDC, 2019)." .

hip1:definition.CH0017 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Oil pollution includes the accidental or deliberate, operational spills of oil from ships, especially tankers, offshore platforms and pipelines (Global Marine Oil Pollution Information Gateway, no date)." .

hip1:definition.CH0022 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Fluoride is a naturally occurring mineral to which the public are often exposed via drinking-water. Depending on dose intake fluoride may have both beneficial effects (reducing the incidence of dental caries) or negative effects (causing tooth enamel and skeletal fluorosis following prolonged high exposure) (adapted from NCBI, 2020 and WHO, no date)." ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.CH0023 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Methanol is a colourless fairly volatile liquid with a faintly sweet pungent odour similar to ethyl alcohol. Outbreaks of methanol poisoning arise from the consumption of adulterated counterfeit or informally produced spirit drinks (adapted from NCBI, 2020 and WHO, 2014)." ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.CH0024 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Substandard and falsified medical products are defined as those that may cause harm to patients and fail to treat the diseases for which they were intended (WHO, 2018)." ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.CH0025 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Marine toxins (biotoxins) are naturally occurring chemicals, mostly caused by certain types of toxic algae, but also by bacteria. These toxins can accumulate in fish and shellfish and present a human health hazard (WHO, no date). When people consume such contaminated aquatic products, depending on the toxins, they can evoke a variety of gastrointestinal and neurological illnesses (paralytic shellfish poisoning, amnesic shellfish poisoning, diarrhoeic shellfish poisoning, neurotoxic shellfish poisoning, azaspiracid shellfish poisoning and ciguatera poisoning)." ;
    hip1:definitionSource hip1:organization.fao,
        hip1:organization.who .

hip1:definition.CHO012 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://ephtracking.cdc.gov/showpesticideFungicides" ;
    skos:definition "Fungicides are chemicals that kill or slow the growth of fungi and their spores. They can be used on plants or other surfaces where mould or mildew grow (CDC, 2019)." ;
    hip1:definitionSource hip1:organization.fao,
        hip1:organization.who .

hip1:definition.EN0001 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Household air pollution is one of the leading causes of disease and premature death and is associated with inefficient cooking practices using polluting stoves paired with solid fuels and kerosene (WHO, 2018)." ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.EN0004 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition """Land degradation means reduction or loss, in arid, semi-arid and dry subhumid areas, of the biological or economic productivity and complexity of rainfed cropland, irrigated cropland or range, pasture, forest and woodlands resulting from land uses or from a process or combination of processes, including processes arising from human activities and habitation patterns such as: soil erosion caused by wind and/or water; deterioration of the physical, chemical and biological or economic properties of soil; and long-term loss of natural vegetation (UNCCD, 1993).\r
\r
Alternative Definition: Land degradation is the reduction in the capability of the land to produce benefits from a particular land use under a specified form of land management (FAO, 1999).\r
\r
Alternative Definition: Land degradation is a negative trend in land condition, caused by direct or indirect human-induced processes including anthropogenic climate change, expressed as long-term reduction or loss of at least one of the following: biological productivity, ecological integrity or value to humans. [Note: This definition applies to forest and non-forest land. Changes in land condition resulting solely from natural processes (such as volcanic eruptions) are not considered to be land degradation. Reduction of biological productivity or ecological integrity or value to humans can constitute degradation, but any one of these changes need not necessarily be considered degradation.] (Olsson et al., 2019).""" ;
    hip1:definitionSource hip1:organization.fao .

hip1:definition.EN0005 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://www.fao.org/soils-portal/about/all-definitions/en" ;
    skos:definition "Soil degradation is defined as a change in soil health status resulting in a diminished capacity of the ecosystem to provide goods and services for its beneficiaries (FAO, 2020)." ;
    hip1:definitionSource hip1:organization.fao .

hip1:definition.EN0006 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Nonpoint sources of pollution refer to pollution sources that are diffused and without a single point of origin or not introduced into a receiving freshwater or maritime environment from a specific outlet. The pollutants are generally carried off the land by storm-water run-off. The commonly used categories for nonpoint sources are agriculture, forestry, urban areas, mining, construction, dams and channels, land disposal and saltwater intrusion (UN data, no date)." .

hip1:definition.EN0007 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition """Saline soils are those which have an electrical conductivity of the saturation soil extract of more than 4 dS/m at 25°C (Richards, 1954). This value is generally used worldwide although the terminology committee of the Soil Science Society of America has lowered the boundary between saline and non-saline soils to 2 dS/m in the saturation extract (FAO, 1988).\r
\r
Note: dS/m = decisiemens per metre this is equivalent to the measurement of electrical conductivity of the salinity which can also be described as millimho per centimetre, hence 1 dS/m = 1 mmho/cm. Once the dS/m is known this can be converted to either mg/L or parts per million (ppm) (University of California, 2020).""" ;
    hip1:definitionSource hip1:organization.fao .

hip1:definition.EN0010 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Forest declines and diebacks are episodic events characterised by premature, progressive loss of tree and stand vigour and health over a given period without obvious evidence of a single clearly identifiable causal factor such as physical disturbance or attack by primary disease or insect (Ciesla and Donaubauer, 1994)." .

hip1:definition.EN0011 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Forest disturbance is the damage caused by any factor (biotic or abiotic) that adversely affects the vigour and productivity of the forest and which is not a direct result of human activities. It includes disturbance by insect pests, diseases, severe weather events and fires (FAO, 2018, 2020)." ;
    hip1:definitionSource hip1:organization.fao .

hip1:definition.EN0012 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Forest invasive species are any species that are non-native to a particular forest ecosystem and whose introduction and spread causes, or are likely to cause, socio-cultural, economic or environmental harm or harm to human health (adapted from FAO, 2015)." ;
    hip1:definitionSource hip1:organization.fao .

hip1:definition.EN0013 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Wildfires are any unplanned or uncontrolled fire affecting natural, cultural, industrial and residential landscapes (adapted from FAO, 2010)." ;
    hip1:definitionSource hip1:organization.fao .

hip1:definition.EN0015 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Mangroves and the destruction of mangrove habitat is caused by both human and natural causes. Human activities in the form of farming, aquaculture, urban development and natural stressors such as erosion and extreme weather have driven mangrove habitat loss. The hazard of loss of mangroves and their ecosystem services has devastating socioeconomic and environmental consequences for coastal communities, especially in those areas with low mangrove diversity and low mangrove area (adapted from Ellison et al., 1996; Polidoro et al., 2010; and Goldberg, 2020)." .

hip1:definition.EN0016 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Wetland loss/degradation is a negative trend in wetland condition, caused by physical or direct/indirect human-induced processes expressed as long-term reduction or loss of at least one of the following: biological productivity, ecological role or value to humans (Craig et al., 1979; Olsson et al., 2019). Where wetlands are defined as areas of marsh, fen, peatland or water, whether natural or artificial, permanent or temporary, with water that is static or flowing, fresh, brackish or salt, including areas of marine water the depth of which at low tide does not exceed six metres (Ramsar Convention 1971: Article 1.1). Wetlands may incorporate riparian and coastal zones adjacent to the wetlands, and islands or bodies of marine water deeper than six metres at low tide lying within the wetlands (Ramsar Convention 1971: Article 2.1)." .

hip1:definition.EN0019 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Soil erosion is defined as the accelerated removal of topsoil from the land surface through water, wind and tillage (FAO, 2020)." .

hip1:definition.EN0021 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Permafrost is defined as the ground that remains frozen under 0°C for a minimum of two consecutive years. Permafrost loss, also known as permafrost thaw is the progressive loss of ground ice in permafrost, usually due to input of heat. Thaw can occur over decades to centuries over the entire depth of permafrost ground, with impacts occurring while thaw progresses. During thaw, temperature fluctuations are subdued because energy is transferred by phase change between ice and water. After the transition from permafrost to non-permafrost, ground can be described as thawed (IPCC, 2019)." .

hip1:definition.EN0022 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Sand mining (extraction) is defined as the removal of primary (virgin) natural sand and sand resources (mineral sands and aggregates) from the natural environment (terrestrial, riverine, coastal, or marine) for extracting valuable minerals, metals, crushed stone, sand and gravel for subsequent processing (UNEP, 2019)." .

hip1:definition.EN0023 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Sea-level change (sea-level rise / sea-level fall) is a change to the height of sea level, both globally and locally (relative sea-level change) at seasonal, annual, or longer time scales due to: a change in ocean volume as a result of a change in the mass of water in the ocean (e.g., due to melt of glaciers and ice sheets); to changes in ocean volume as a result of changes in ocean water density (e.g., expansion under warmer conditions), and to changes in the shape of the ocean basins and changes in the Earth’s gravitational and rotational fields, and local subsidence or uplift of the land (IPCC, 2019)." .

hip1:definition.EN0024 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Eutrophication is the overabundance of nutrients in a body of water that results in harmful algal blooms, fish kills, and in some cases ecosystem collapse. It is a process driven by enrichment of water by nutrients, particularly compounds of nitrogen and/or phosphorus, leading to increased growth, primary production and biomass of algae; changes in the balance of nutrients causing changes to the balance of organisms; and water quality degradation (NOAA, 2007; UNEP, 2015)." .

hip1:definition.ET0002 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A geomagnetic storm is a worldwide disturbance of the Earth’s magnetic field induced by a solar storm" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.ET0003 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "UV radiation is the portion of the electromagnetic (EM) spectrum between X-rays and visible light. Depending on its wavelength, UV radiation can penetrate the ozone layer and affect human health in different ways (Government of Canada, 2019)." .

hip1:definition.ET0004 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A meteorite is an object that survives a trip through Earth’s atmosphere and hits the ground (adapted from NASA, no date)." ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.ET0005 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition """An ionospheric storm is defined as turbulence in the F region of the ionosphere, usually due to a sudden burst of radiation from the Sun (WMO, 1992).\r
\r
NB. The F region is the highest region of the ionosphere, at altitudes greater than 160 km (100 miles).""" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.ET0006 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Radio blackout is a prolonged period of fading or faded radio communications, primarily in the high frequency range from ionospheric changes because of increased solar activity, in particular solar flares of C-class level or higher on the sunlit side of Earth" .

hip1:definition.ET0007 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Solar radiation storms occur when large quantities of charged particles, primarily protons, accelerated by eruptive processes at or near the Sun reach the near-Earth environment" .

hip1:definition.ET0008 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A space accident is any accident involving space objects that causes damage" .

hip1:definition.ET0009 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A near-Earth object (NEO) is an asteroid or comet whose trajectory brings it to within 1.3 astronomical units of the Sun and hence within 0.3 astronomical units, or approximately 45 million kilometres, of the Earth’s orbit" .

hip1:definition.GH0001 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://www.usgs.gov/glossary/earthquake-hazards-program" ;
    skos:definition "Earthquake is a term used to describe both sudden slip on a fault, and the resulting ground shaking and radiated seismic energy caused by the slip, or by volcanic or magmatic activity, or other sudden stress changes in the Earth" ;
    hip1:definitionSource hip1:organization.usgs .

hip1:definition.GH0002 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Earthquake ground shaking is the movement of the Earth’s surface produced by seismic waves that are generated when an earthquake occurs." ;
    hip1:definitionSource hip1:organization.gem .

hip1:definition.GH0003 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://www.americangeosciences.org/word/liquefaction-soil" ;
    skos:definition "Soil liquefaction occurs when soil is transformed from a solid to a liquid state as a result of increased pore pressure and reduced effective stress. It is typically caused by rapid loading of the soil during earthquake shaking (AGI, 2017)." ;
    hip1:definitionSource hip1:organization.gem .

hip1:definition.GH0005 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Tectonic uplift and subsidence are the distributed vertical permanent ground deformations (warping) that result from earthquake displacements on a dipping (inclined) fault (Styron, 2019). This includes changes to the shoreline as a result of uplift and subsidence." ;
    hip1:definitionSource hip1:organization.gem .

hip1:definition.GH0006 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Tsunami is the Japanese term meaning wave (‘nami’) in a harbour (‘tsu’). It is a series of travelling waves of extremely long length and period, usually generated by disturbances associated with earthquakes occurring below or near the ocean floor (IOC, 2019)." ;
    hip1:definitionSource hip1:organization.bgs,
        hip1:organization.unesco .

hip1:definition.GH0007 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Landslide is the downslope movement of soil, rock and organic materials under the effects of gravity, which occurs when the gravitational driving forces exceed the frictional resistance of the material resisting on the slope. Landslides could be terrestrial or submarine (Varnes, 1978)." ;
    hip1:definitionSource hip1:organization.bgs .

hip1:definition.GH0008 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Ground gases generated in the ground from magma (molten or semimolten natural material derived from the melting of land or oceanic crust) include carbon dioxide, sulphur dioxide, hydrogen sulphide and hydrogen halides (adapted from IVHHN, 2020 and USGS, no date)." ;
    hip1:definitionSource hip1:organization.gem .

hip1:definition.GH0009 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A lava flow or lava dome is a body of lava that forms during an eruption, or main eruptive episode. Lava flows are outpourings of fluid, relatively low-viscosity molten rock, whereas a lava dome is a pile of relatively viscous lava that cannot flow far from the vent (Calder et al., 2015; Kilburn, 2015)." ;
    hip1:definitionSource hip1:organization.gvm,
        hip1:organization.iavcei,
        hip1:organization.ivhhn .

hip1:definition.GH0012 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Pyroclastic density currents are hot, fast-moving mixtures of volcanic particles and gas that flow according to their density relative to the surrounding medium and the Earth’s gravity. They typically originate from the gravitational collapse of explosive eruption columns, lava domes or lava-flow fronts, and from explosive lateral blasts (adapted from Branney and Kokelaar, 2002 and Cole et al., 2015)." ;
    hip1:definitionSource hip1:organization.gvm,
        hip1:organization.iavcei,
        hip1:organization.ivhhn .

hip1:definition.GH0014 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A landslide is the downslope movement of soil, rock and organic materials under the effects of gravity, which occurs when the gravitational driving forces exceed the frictional resistance of the material resisting on the slope. Landslides could be terrestrial or submarine (Varnes, 1978)." ;
    hip1:definitionSource hip1:organization.bgs .

hip1:definition.GH0015 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition """Ground shaking is the movement of the Earth’s surface from earthquakes. Ground shaking is produced by waves that travel through the earth and along its surface (USGS, no date).\r
\r
A volcanic earthquake is any earthquake that results from tectonic forces which occur in conjunction with volcanic activity (UN-SPIDER, no date).""" ;
    hip1:definitionSource hip1:organization.bgs .

hip1:definition.GH0016 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Volcanic gas includes any gas-phase substance that is emitted by volcanic or volcanic-geothermal activity. Volcanic aerosols include liquid or solid particles that are small enough to be suspended in the air, and that are emitted by volcanic or volcanic-geothermal activity (adapted from Baxter and Horwell, 2015, Fischer and Chiodini 2015, and Williams- Jones and Rymer 2015)." .

hip1:definition.GH0017 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Volcano tsunamis (pronounced soo-ná-mees), are a series of waves created when water surrounding a volcano is displaced following an eruption, a landslide, or failure of a volcanic edifice into surrounding water. If the generating mechanism is large enough, the waves can be significant on local, regional or even transoceanic scales (Day, 2015)." ;
    hip1:definitionSource hip1:organization.bgs,
        hip1:organization.unesco .

hip1:definition.GH0018 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Volcanic lightning is an electrical discharge caused by a volcanic eruption. It is typically associated with ash-rich eruption plumes but can also arise from a range of volcanic processes including ground-hugging ash flows and lava-ocean entry (adapted from Mather and Harrison, 2006; Behnke and McNutt, 2014; and McNutt and Thomas, 2015)." ;
    hip1:definitionSource hip1:organization.usgs .

hip1:definition.GH0019 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Urban fires are fire involving buildings or structures in cities or towns with potential to spread to adjoining structures. Triggers of urban fires are numerous, from human actions (e.g., knocking over a candle) and technological triggers (e.g., power surge overloading appliances), to natural triggers (e.g., wildland fires interacting with urban areas). Triggers from volcanic eruptions include lava flows, pyroclastic density currents, tephra, and ground shaking (adapted from Baxter et al., 2005 and ISO, 2020)." .

hip1:definition.GH0020 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Volcanic uplift and subsidence are deformations of the ground associated with volcanic unrest and eruptions (Dzurisin, 2007)." ;
    hip1:definitionSource hip1:organization.bgs .

hip1:definition.GH0021 a owl:NamedIndividual,
        hip1:Definition ;
    hip1:definitionSource hip1:organization.bgs .

hip1:definition.GH0022 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Liquefaction is the term applied to the loss of strength experienced in loosely packed, saturated or close to saturated sediments at or near the ground surface in response to strong ground shaking, such as earthquakes, cyclic loading, and vibration from machinery, or due to the development of excess pore pressure resulting from a change in head or confining pressures. The loss of strength causes the soil to behave like a viscous fluid, sometimes referred to as ‘running sand’, until the excess pore pressure returns to hydrostatic (USGS, no date)." ;
    hip1:definitionSource hip1:organization.bgs .

hip1:definition.GH0023 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://azgs.arizona.edu/center-natural-hazards/earth-fissures-subsidence-karst-arizona#:~:text=Earth%20Fissures%20are%20open%20ground,sinking%20of%20the%20Earth%E2%80%99s%20surface" ;
    skos:definition "Ground fissures form in response to tensional stresses, most commonly in unconsolidated sediment, but also in rock (Arizona Geological Survey, 2020)." ;
    hip1:definitionSource hip1:organization.bgs .

hip1:definition.GH0024 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://www.bgs.ac.uk/geology-projects/shallow-geohazards/clay-shrink-swell/" ;
    skos:definition "Subsidence is a lowering or collapse of the ground (BGS, 2020). Uplift is the converse." ;
    hip1:definitionSource hip1:organization.bgs .

hip1:definition.GH0025 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "http://www.bgs.ac.uk/geology-projects/shallow-geohazards/clay-shrink-swell" ;
    skos:definition "Subsidence is a lowering or collapse of the ground, caused by various factors, including groundwater lowering, sub-surface mining or tunnelling, consolidation, sinkholes, or changes in moisture content in expansive soils. Shrink-swell is the term applied to the behaviour of expansive soils, which are a group of soils that exhibit volumetric change in response to changes in moisture content, such that they shrink in response to desiccation and swell by hydration, resulting in ground subsidence and ground heave respectively (BGS, 2020)." ;
    hip1:definitionSource hip1:organization.bgs .

hip1:definition.GH0026 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A sinkhole is a closed depression in karst (a landscape resulting from the dissolution of soluble rock) by current or palaeo internal drainage, also known as a doline. This is one of several hazards that result in subsidence, i.e., lowering or collapse of the ground (adapted from USGS, no date; and BGS, no date)." ;
    hip1:definitionSource hip1:organization.bgs .

hip1:definition.GH0027 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Ground gases that result from material decay (natural or anthropogenic) typically include radon, methane, carbon dioxide, hydrogen sulphide, but may also include the break down products of other compounds, such as nitrogen, alcohols, alkanes, cycloalkanes and alkenes, aromatic hydrocarbons (monocyclic or polycyclic); esters and ethers, as well as halogenated compounds and organosulphur. Ground gases derived from magma (molten or semi-molten natural material derived from the melting of land or oceanic crust) include carbon dioxide, sulphur dioxide, hydrogen sulphide and hydrogen halides. Ground gases are gases released in combination with water vapour and particulate matter during volcanogenic events, or via fumaroles, and hydrothermal systems (adapted from NHBC (UK), 2007; IVHHN, 2020; US EPA, no date; and USGS, no date)." ;
    hip1:definitionSource hip1:organization.bgs .

hip1:definition.GH0028 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "https://www.usgs.gov/media/images/stream-bank-erosion-mobilizes-sediment-can-be-transported-downstr" ;
    skos:definition "Riverbank erosion is the removal of material from the banks of rivers when flowing water forces exceed bank resisting forces by the soil and vegetation, for example, when river levels are sufficiently high, primarily due to fluvial energy and atmospheric processes and secondarily because of the resultant geotechnical instability and consequential riverbank failure. Riverbank failure can also occur as a consequence of Earth hazards, such as volcanos and earthquakes (USDA, no date)." ;
    hip1:definitionSource hip1:organization.bgs .

hip1:definition.GH0029 a owl:NamedIndividual,
        hip1:Definition ;
    terms:references "http://www.fao.org/3/a-i1488e.pdf" ;
    skos:definition "Sand encroachment occurs generally in arid to semi-arid regions when grains of sand are carried by winds and form sandy accumulation on coasts, along water courses and on cultivated or uncultivated land. As the accumulations of sand (dunes) move, they bury towns, roads, oases, crops, market gardens, irrigation channels and dams, thus causing major material and socioeconomic damage (FAO, 2010)." ;
    hip1:definitionSource hip1:organization.fao .

hip1:definition.GH0031 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A submarine landslide is a downslope movement of sediment or rock under the effect of gravity, which occurs when the stresses acting downslope exceed the available strength of the sediment on the slope (Lee et al., 2007)." ;
    hip1:definitionSource hip1:organization.bgs .

hip1:definition.GH0032 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Rockfall is a fragment of rock (a block) detached by sliding, toppling, or falling, that falls along a vertical or sub-vertical cliff, and proceeds down slope by bouncing and flying along ballistic trajectories or by rolling on talus or debris slopes (Highland and Bobrowsky, 2008)." ;
    hip1:definitionSource hip1:organization.bgs .

hip1:definition.GH0033 a owl:NamedIndividual,
        hip1:Definition ;
    hip1:definitionSource hip1:organization.bgs .

hip1:definition.GH0034 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Rock avalanches are a translational form of mass movement where the transported material is dry rock that is fragmented before or during slope failure. They are rapid with long runouts and large volumes and often involve the entrainment of slope material, commonly therefore, giving rise to debris slides or flows. The motion of rock avalanches is massive such that the bulk of the rock fragments move together as a largely coherent mass (adapted from Collins, 2014 and USGS, no date)." ;
    hip1:definitionSource hip1:organization.bgs .

hip1:definition.MH0002 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Lightning is the luminous manifestation accompanying a sudden electrical discharge which takes place from or inside a cloud or, less often, from high structures on the ground or from mountains" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0003 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A thunderstorm is defined as one or more sudden electrical discharges, manifested by a flash of light (lightning) and a sharp or rumbling sound (thunder)" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0007 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A fluvial flood is a rise, usually brief, in the water level of a stream or water body to a peak from which the water level recedes at a slower rate" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0008 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A groundwater flood is the emergence of groundwater at the ground surface away from perennial river channels or the rising of groundwater into man-made ground, under conditions where the ‘normal’ ranges of groundwater level and groundwater flow are exceeded" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0009 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition """An ice jam flood including debris is defined as an accumulation of shuga including ice cakes, below ice cover. It is broken ice in a river which causes a narrowing of the river channel, a rise in water level and local floods (WMO, 2012).\r
\r
Shuga is defined as accumulation of spongy white ice lumps, a few centimetres across, formed from grease ice or slush, and sometimes from anchor ice rising to the surface (WMO, 2012).""" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0010 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A ponding flood is a flood which results from rainwater ponding at or near the point where it falls because it is falling faster than the drainage system (natural or man-made) can carry it away" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0011 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A snowmelt flood is a significant flood rise in a river caused by the melting of snowpack accumulated during the winter" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0012 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Surface water flooding is that part of the rain which remains on the ground surface during rain and either runs off or infiltrates after the rain ends, not including depression storage" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0013 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A ‘glacial lake outburst flood’ is a phrase used to describe a sudden release of a significant amount of water retained in a glacial lake, irrespective of the cause" ;
    hip1:definitionSource hip1:organization.who .

hip1:definition.MH0017 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Haze is a suspension in the air of extremely small, dry particles invisible to the naked eye and sufficiently numerous to give the air an opalescent appearance" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0018 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition """Polluted air is air containing dust, smoke, micro-organisms or gases different from those from which it would normally be composed (WMO, 1992).\r
\r
Alternative definition: Polluted air is air which contains gases and particles emitted to the atmosphere by a variety of human activities and natural sources, or formed in the atmosphere, that at critical levels have harmful effects on human health, animals, plants and ecosystems, or reduce visibility and corrode materials, buildings and cultural heritage sites (UNEP, no date).""" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0019 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Sand haze is haze caused by the suspension in the atmosphere of small sand or dust particles, raised from the ground prior to the time of observation by a sandstorm or dust storm" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0020 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Smoke is a suspension in the air of small particles produced by combustion" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0021 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Ocean acidification refers to a reduction in the pH of the ocean over an extended period, which is caused primarily by uptake of carbon dioxide from the atmosphere and can also be caused by other chemical additions or subtractions from the ocean" ;
    hip1:definitionSource hip1:organization.ipcc .

hip1:definition.MH0022 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Rogue waves are extreme waves with overall or crest heights that are abnormally high relative to the background significant wave height" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0023 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Seawater intrusion is the process by which saltwater infiltrates a coastal aquifer, leading to contamination of fresh groundwater" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0024 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Sea ice is any form of ice found at sea" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0025 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Ice flow is the motion of ice driven by gravitational forces, ice stress or, for sea ice, wind, water currents and tide" .

hip1:definition.MH0026 a owl:NamedIndividual,
        hip1:Definition ;
    hip1:definitionSource hip1:organization.wmo ;
    hip1:synonym "Seiches are sea-level oscillations at the resonant frequency of enclosed bodies of water" .

hip1:definition.MH0027 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A storm surge reflects the difference between the actual water level under the influence of a meteorological disturbance (storm tide) and the level which would have occurred in the absence of the meteorological disturbance (i.e., astronomical tide)" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0028 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A storm tides is the actual sea level as influenced by a weather disturbance. The storm tide consists of the normal astronomical tide plus the storm surge" .

hip1:definition.MH0029 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Tsunami is the Japanese term meaning wave (‘nami’) in a harbour (‘tsu’). It is a series of travelling waves of extremely long length and period, usually generated by disturbances associated with earthquakes occurring below or near the ocean floor" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0031 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "An extra-tropical cyclone is a low-pressure system which develops in latitudes outside the tropics" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0032 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A sub-tropical cyclone is a non-frontal low-pressure system that has characteristics of both tropical and extratropical cyclones. Like tropical cyclones, they are non-frontal, synoptic-scale cyclones that originate over tropical or subtropical waters and have a closed surface wind circulation about a welldefined centre" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0036 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Hail is precipitation in the form of particles of ice (hailstones). These can be either transparent, or partly or completely opaque. They are usually spheroidal, conical or irregular in form, and generally 5−50 mm in diameter. The particles may fall from a cloud either separately or agglomerated in irregular lumps" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0037 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "An ice storm involves the intense formation of ice on objects by the freezing, on impact, of rain or drizzle" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0038 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Snow is the precipitation of ice crystals, isolated or agglomerated, falling from a cloud" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0039 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A snow storm is a meteorological disturbance giving rise to a heavy fall of snow, often accompanied by strong winds" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0047 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A heatwave is a marked warming of the air, or the invasion of very warm air, over a large area; it usually lasts from a few days to a few weeks (WMO, 1992). Alternative definition: A heatwave is a marked unusual period of hot weather over a region persisting for at least two consecutive days during the hot period of the year based on local climatological conditions, with thermal conditions recorded above given thresholds" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0048 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Icing refers to any deposit or coating of ice on an object caused by the impact of liquid hydrometeors, usually supercooled" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0049 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Thaw is the melting of snow or ice at the Earth’s surface due to a temperature rise above 0°C" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0051 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A mud flow is a flow of water so heavily charged with sediment and debris that the flowing mass is thick and viscous" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0052 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A rock slide is a movement of a mass of soil or rock on an individualized failure surface" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0055 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A squall is an atmospheric phenomenon characterised by a very large variation of wind speed: it begins suddenly, has a duration of the order of minutes and decreases suddenly in speed. It is often accompanied by a shower or thunderstorm" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0056 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A subtropical storm is a subtropical cyclone in which the maximum sustained surface wind speed (using the U.S. 1-minute average) is 34 kt (39 mph or 63 km/hr) or more" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0057 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition """A tropical cyclone is a cyclone of tropical origin of small diameter (some hundreds of kilometres) with a minimum surface pressure in some cases of less than 900 hPa, very violent winds and torrential rain; sometimes accompanied by thunderstorms. It usually contains a central region, known as the ‘eye’ of the storm, with a diameter of the order of some tens of kilometres, and with light winds and a more or less lightly clouded sky (WMO, 2017).\r
\r
Alternative definition: A tropical cyclone is a warm-core, non-frontal synoptic-scale cyclone, originating over tropical or subtropical waters, with organised deep convection and closed surface wind circulation about a well-defined centre""" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0058 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition """A tropical storm is a rapid rotating storm originating over tropical oceans. It has a low pressure centre and clouds spiralling towards the eyewall surrounding the ‘eye’. Its diameter is typically around 200 to 500 km, but can reach 1000 km. The related hazards are very violent winds, torrential rain, high waves, storm surges and in some cases tornadoes, causing direct effects such as flash floods, flooding, coastal inundation, and indirect effects such as landslides and mudslides. The winds blow anti-clockwise in the Northern Hemisphere and clockwise in the Southern Hemisphere (WMO, 2020).\r
\r
The intensity of tropical storms is based on the wind speed. A tropical storm is a tropical cyclone with the maximum sustained winds of 34 knots (17.5 m/s, 63 km/h) to 47 knots (24.2 m/s, 87 km/h) near the centre. When reaching this intensity, they are named in the interests of public safety""" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0059 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "A tornado is a rotating column of air, extending from the base of a cumuliform cloud, and often visible as a condensation funnel in contact with the ground, and/or attendant circulating dust or debris cloud at the ground" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definition.MH0060 a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition "Wind is air motion relative to the Earth’s surface. Unless otherwise specified, only the horizontal component is considered" ;
    hip1:definitionSource hip1:organization.wmo .

hip1:definitionSource a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:hadPrimarySource .

hip1:describedAs a owl:ObjectProperty ;
    rdfs:label "described as" .

hip1:hasMember a owl:ObjectProperty ;
    rdfs:label "has member" ;
    rdfs:subPropertyOf skos:member ;
    owl:inverseOf hip1:isMemberOf .

hip1:identifier a owl:AnnotationProperty ;
    rdfs:subPropertyOf terms:identifier .

hip1:synonym a owl:AnnotationProperty .

hip1:vernacularName a owl:AnnotationProperty .

deo1:hasPossiblyCausesRelation a owl:ObjectProperty ;
    rdfs:label "has possibly causes relation" ;
    schema1:domainIncludes "Disaster",
        "Hazard" ;
    schema1:rangeIncludes "'Possibly Causes Relation'" .

deo1:resultsIn a owl:ObjectProperty ;
    rdfs:label "results in" ;
    schema1:domainIncludes "'Possibly Causes Relation'" ;
    schema1:rangeIncludes "Disaster",
        "Hazard" .

<http://knowwheregraph/ontology/deo/Hazard> a owl:Class ;
    rdfs:label "Hazard" ;
    rdfs:subClassOf <http://knowwheregraph/ontology/deo/Event> ;
    skos:description "A process, phenomenon or human activity that may cause loss of life, injury or other health impacts, property damage, social and economic disruption or environmental degradation. Hazards may be natural, anthropogenic or socionatural in origin. Hazards may be single, sequential or combined in their origin and effects. Each hazard is characterized by its location, intensity or magnitude, frequency and probability. Biological hazards are also defined by their infectiousness or toxicity, or other characteristics of the pathogen such as dose-response, incubation period, case fatality rate and estimation of the pathogen for transmission. (Source: UNDRR Glossary - https://www.undrr.org/terminology)" .

<http://knowwheregraph/ontology/dmdo/resultsIn> a owl:ObjectProperty ;
    rdfs:label "results in" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dmdo/Hazard> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dmdo/Disaster> .

<http://knowwheregraph/ontology/dpo/hasCapacity> a owl:ObjectProperty ;
    rdfs:label "has capacity" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dmdo/ElementAtRisk> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dpo/AdaptiveCapacity> ;
    rdfs:subPropertyOf ssn:hasProperty .

<http://knowwheregraph/ontology/dpo/hasExposure> a owl:ObjectProperty ;
    rdfs:label "has exposure" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dmdo/ElementAtRisk> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dpo/LevelOfExposure> ;
    rdfs:subPropertyOf ssn:hasProperty .

<http://knowwheregraph/ontology/dpo/intensityOfDisaster> a owl:ObjectProperty ;
    rdfs:label "intensity of disaster" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dpo/Intensity> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dmdo/Disaster> ;
    rdfs:subPropertyOf ssn:isPropertyOf .

<http://knowwheregraph/ontology/dpo/resilienceOfElementAtRisk> a owl:ObjectProperty ;
    rdfs:label "resilience of element-at-risk" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dpo/Resilience> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dmdo/ElementAtRisk> ;
    rdfs:subPropertyOf ssn:isPropertyOf .

<http://knowwheregraph/ontology/dpo/riskOfElementAtRisk> a owl:ObjectProperty ;
    rdfs:label "risk of element-at-risk" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dpo/DisasterRisk> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dmdo/ElementAtRisk> ;
    rdfs:subPropertyOf ssn:isPropertyOf .

<http://knowwheregraph/ontology/dpo/severityOfImpact> a owl:ObjectProperty ;
    rdfs:label "severity of impact" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dpo/Severity> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dmdo/DisasterImpact> ;
    rdfs:subPropertyOf ssn:isPropertyOf .

<http://knowwheregraph/ontology/dpo/vulnerabilityOfElementAtRisk> a owl:ObjectProperty ;
    rdfs:label "vulnerability of element-at-risk" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dpo/Vulnerability> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dmdo/ElementAtRisk> ;
    rdfs:subPropertyOf ssn:isPropertyOf .

terms:identifier a owl:AnnotationProperty .

skos:Collection a owl:Class .

skos:broader a owl:ObjectProperty .

skos:member a owl:ObjectProperty .

skos:narrower a owl:ObjectProperty .

time:TemporalEntity a owl:Class .

org:Organization a owl:Class .

<https://mazu.cma/saudi#DataSource/SST> a prov:Entity ;
    rdfs:label "SST" ;
    rdfs:comment "OSTIA SST, 0.05 deg, 2007-present" .

<https://mazu.cma/saudi#HazardType/coastal_humid_heat> a deo:HazardType,
        hip:SpecificHazard ;
    rdfs:label "Coastal Humid Heat" .

<https://mazu.cma/saudi#HazardType/dust_storm> a deo:HazardType,
        hip:SpecificHazard ;
    rdfs:label "Dust Storm" .

<https://mazu.cma/saudi#HazardType/extreme_heat> a deo:HazardType,
        hip:SpecificHazard ;
    rdfs:label "Extreme Heat" .

<https://mazu.cma/saudi#HazardType/flash_flood> a deo:HazardType,
        hip:SpecificHazard ;
    rdfs:label "Flash Flood" .

<https://mazu.cma/saudi#Indicator/absolute_vorticity850> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "absolute_vorticity850" ;
    qudt:unit qudt:PER-SEC ;
    rdfs:comment "850 hPa绝对涡度，综合地转和相对旋转背景" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/relative_vorticity850> ;
    saudi:effectiveDays 293 ;
    saudi:expression "absv" ;
    saudi:hasDAG "{\"op\": \"var\", \"name\": \"absv\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/cin> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "cin" ;
    qudt:unit qudt:J-PER-KiloGM ;
    rdfs:comment "对流抑制能量，越负抑制越强" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/cape>,
        <https://mazu.cma/saudi#Indicator/surface_lifted_index> ;
    saudi:effectiveDays 293 ;
    saudi:expression "若源变量带额外层维度，先对非水平维取最小值" ;
    saudi:hasDAG "{\"op\": \"min_over_dim\", \"var\": \"cin_raw\", \"dim\": \"pressureFromGroundLayer\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/convective_precip_ratio> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "convective_precip_ratio" ;
    qudt:unit qudt:UNITLESS ;
    rdfs:comment "日对流降水占比，表示降水对流性" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/cape>,
        <https://mazu.cma/saudi#Indicator/daily_convective_precip>,
        <https://mazu.cma/saudi#Indicator/daily_large_scale_precip> ;
    saudi:effectiveDays 2 ;
    saudi:expression "cpr / prate" ;
    saudi:hasDAG "{\"op\": \"div\", \"left\": {\"op\": \"var\", \"name\": \"cpr\"}, \"right\": {\"op\": \"var\", \"name\": \"prate\"}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/daily_precip_climatology_station_distance_km> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "daily_precip_climatology_station_distance_km" ;
    qudt:unit qudt:KiloM ;
    rdfs:comment "降水气候态最近站距离，越大局地不确定性越高" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS8> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/daily_precip_climatology> ;
    saudi:effectiveDays 363 ;
    saudi:expression "网格点到所用 DS8 PRE 站的球面距离" ;
    saudi:hasDAG "{\"op\": \"ds8_station_distance\", \"element\": \"PRE\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/divergence850> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "divergence850" ;
    qudt:unit qudt:PER-SEC ;
    rdfs:comment "850 hPa水平散度，正值发散负值辐合" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/relative_vorticity850> ;
    saudi:effectiveDays 291 ;
    saudi:expression "du/dx + dv/dy" ;
    saudi:hasDAG "{\"op\": \"spatial_divergence\", \"u_var\": \"u850\", \"v_var\": \"v850\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/ds10_ds2_heavy_rain_overlap> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "ds10_ds2_heavy_rain_overlap" ;
    rdfs:comment "DS10与DS2强降水重叠标志" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS10>,
        <https://mazu.cma/saudi#DataSource/DS2>,
        <https://mazu.cma/saudi#Indicator/daily_precip_total>,
        <https://mazu.cma/saudi#Indicator/ds10_daily_total> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/daily_precip_total>,
        <https://mazu.cma/saudi#Indicator/ds10_ds2_precip_diff> ;
    saudi:effectiveDays 271 ;
    saudi:expression "两者均>=10mm时为1" ;
    saudi:hasDAG "{\"op\": \"and_\", \"left\": {\"op\": \"threshold\", \"left\": {\"op\": \"var\", \"name\": \"ds10_daily_total\"}, \"condition\": \">=\", \"right\": 10}, \"right\": {\"op\": \"threshold\", \"left\": {\"op\": \"var\", \"name\": \"daily_precip_total\"}, \"condition\": \">=\", \"right\": 10}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/ds10_max_30min> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "ds10_max_30min" ;
    qudt:unit qudt:MilliM ;
    rdfs:comment "DS10 30分钟最大降水" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS10> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/ds10_max_1h>,
        <https://mazu.cma/saudi#Indicator/flash_flood_risk> ;
    saudi:effectiveDays 273 ;
    saudi:expression "max_30min, 最近邻重采样" ;
    saudi:hasDAG "{\"op\": \"nearest_resample\", \"var\": \"ds10_max_30min_raw\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/ds10_max_6h> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "ds10_max_6h" ;
    qudt:unit qudt:MilliM ;
    rdfs:comment "DS10 6小时最大降水" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS10> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/ds10_max_3h> ;
    saudi:effectiveDays 273 ;
    saudi:expression "max_6h, 最近邻重采样" ;
    saudi:hasDAG "{\"op\": \"nearest_resample\", \"var\": \"ds10_max_6h_raw\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/heat_stress_index> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "heat_stress_index" ;
    qudt:unit qudt:W-PER-M2 ;
    rdfs:comment "日地表热胁迫代理，越高代表吸收太阳能和感热通量越强" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/bowen_ratio>,
        <https://mazu.cma/saudi#Indicator/heat_index_c>,
        <https://mazu.cma/saudi#Indicator/t2m_c> ;
    saudi:effectiveDays 364 ;
    saudi:expression "avg_ishf + (1 - avg_al/100) * sdswrf" ;
    saudi:hasDAG "{\"op\": \"add\", \"left\": {\"op\": \"var\", \"name\": \"avg_ishf\"}, \"right\": {\"op\": \"mul\", \"left\": {\"op\": \"sub\", \"left\": 1, \"right\": {\"op\": \"div\", \"left\": {\"op\": \"var\", \"name\": \"avg_al\"}, \"right\": 100}}, \"right\": {\"op\": \"var\", \"name\": \"sdswrf\"}}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/high_cloud_cover> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "high_cloud_cover" ;
    qudt:unit qudt:Percent ;
    rdfs:comment "高云量" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/cape>,
        <https://mazu.cma/saudi#Indicator/daily_convective_precip>,
        <https://mazu.cma/saudi#Indicator/total_cloud_cover> ;
    saudi:effectiveDays 365 ;
    saudi:expression "tcc_highCloudLayer_0_0" ;
    saudi:hasDAG "{\"op\": \"var\", \"name\": \"tcc_highCloudLayer_0_0\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/jet300_speed> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "jet300_speed" ;
    qudt:unit qudt:M-PER-SEC ;
    rdfs:comment "300 hPa风速，高空急流背景" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/jet200_speed>,
        <https://mazu.cma/saudi#Indicator/wind_shear_850_300> ;
    saudi:effectiveDays 292 ;
    saudi:expression "sqrt(u300^2 + v300^2)" ;
    saudi:hasDAG "{\"op\": \"sqrt\", \"left\": {\"op\": \"add\", \"left\": {\"op\": \"sqr\", \"left\": {\"op\": \"var\", \"name\": \"u300\"}}, \"right\": {\"op\": \"sqr\", \"left\": {\"op\": \"var\", \"name\": \"v300\"}}}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/low_cloud_cover> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "low_cloud_cover" ;
    qudt:unit qudt:Percent ;
    rdfs:comment "低云量" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/rh2m>,
        <https://mazu.cma/saudi#Indicator/total_cloud_cover> ;
    saudi:effectiveDays 365 ;
    saudi:expression "tcc_lowCloudLayer_0_0" ;
    saudi:hasDAG "{\"op\": \"var\", \"name\": \"tcc_lowCloudLayer_0_0\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/middle_cloud_cover> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "middle_cloud_cover" ;
    qudt:unit qudt:Percent ;
    rdfs:comment "中云量" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/daily_large_scale_precip>,
        <https://mazu.cma/saudi#Indicator/total_cloud_cover> ;
    saudi:effectiveDays 365 ;
    saudi:expression "tcc_middleCloudLayer_0_0" ;
    saudi:hasDAG "{\"op\": \"var\", \"name\": \"tcc_middleCloudLayer_0_0\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/moisture_transport850> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "moisture_transport850" ;
    qudt:unit qudt:M-PER-SEC ;
    rdfs:comment "850 hPa水汽输送强度" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/wind850_speed> ;
    saudi:effectiveDays 291 ;
    saudi:expression "q850 * wind850_speed" ;
    saudi:hasDAG "{\"op\": \"mul\", \"left\": {\"op\": \"var\", \"name\": \"q850\"}, \"right\": {\"op\": \"var\", \"name\": \"wind850_speed\"}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/moisture_transport925> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "moisture_transport925" ;
    qudt:unit qudt:M-PER-SEC ;
    rdfs:comment "925 hPa水汽输送强度，低层水汽输送代理" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/wind925_speed> ;
    saudi:effectiveDays 291 ;
    saudi:expression "q925 * wind925_speed" ;
    saudi:hasDAG "{\"op\": \"mul\", \"left\": {\"op\": \"var\", \"name\": \"q925\"}, \"right\": {\"op\": \"var\", \"name\": \"wind925_speed\"}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/monthly_bowen_ratio> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "monthly_bowen_ratio" ;
    qudt:unit qudt:UNITLESS ;
    rdfs:comment "月 Bowen 比，感热相对潜热越高地表越干热" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS1> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/monthly_heat_stress_index> ;
    saudi:effectiveDays 365 ;
    saudi:expression "avg_ishf / avg_slhtf" ;
    saudi:hasDAG "{\"op\": \"div\", \"left\": {\"op\": \"var\", \"name\": \"avg_ishf\"}, \"right\": {\"op\": \"var\", \"name\": \"avg_slhtf\"}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/monthly_convective_precip_ratio> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "monthly_convective_precip_ratio" ;
    qudt:unit qudt:UNITLESS ;
    rdfs:comment "月对流降水占比，越高说明降水更偏对流性" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS1>,
        <https://mazu.cma/saudi#Indicator/monthly_convective_precip>,
        <https://mazu.cma/saudi#Indicator/monthly_precip_total> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/monthly_convective_precip> ;
    saudi:effectiveDays 365 ;
    saudi:expression "monthly_convective_precip / monthly_precip_total" ;
    saudi:hasDAG "{\"op\": \"div\", \"left\": {\"op\": \"var\", \"name\": \"monthly_convective_precip\"}, \"right\": {\"op\": \"var\", \"name\": \"monthly_precip_total\"}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/monthly_heat_stress_index> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "monthly_heat_stress_index" ;
    qudt:unit qudt:W-PER-M2 ;
    rdfs:comment "月地表热胁迫代理，结合感热通量和吸收短波" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS1> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/monthly_bowen_ratio> ;
    saudi:effectiveDays 365 ;
    saudi:expression "avg_ishf + (1 - avg_al/100) * sdswrf" ;
    saudi:hasDAG "{\"op\": \"add\", \"left\": {\"op\": \"var\", \"name\": \"avg_ishf\"}, \"right\": {\"op\": \"mul\", \"left\": {\"op\": \"sub\", \"left\": 1, \"right\": {\"op\": \"div\", \"left\": {\"op\": \"var\", \"name\": \"avg_al\"}, \"right\": 100}}, \"right\": {\"op\": \"var\", \"name\": \"sdswrf\"}}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/monthly_precip_mmday> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "monthly_precip_mmday" ;
    qudt:unit qudt:MilliM-PER-DAY ;
    rdfs:comment "月平均降水强度，月累计除以当月天数" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS1>,
        <https://mazu.cma/saudi#Indicator/monthly_precip_total> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/monthly_precip_total> ;
    saudi:effectiveDays 365 ;
    saudi:expression "monthly_precip_total / days_in_month" ;
    saudi:hasDAG "{\"op\": \"div\", \"left\": {\"op\": \"var\", \"name\": \"monthly_precip_total\"}, \"right\": \"days_in_month\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/monthly_uvb_clear_ratio> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "monthly_uvb_clear_ratio" ;
    qudt:unit qudt:UNITLESS ;
    rdfs:comment "晴空/全天 UV-B 比，衡量云和气溶胶对 UV-B 的调制" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS1> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/monthly_uvb_flux> ;
    saudi:effectiveDays 365 ;
    saudi:expression "cduvb / duvb" ;
    saudi:hasDAG "{\"op\": \"div\", \"left\": {\"op\": \"var\", \"name\": \"cduvb\"}, \"right\": {\"op\": \"var\", \"name\": \"duvb\"}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/monthly_uvb_flux> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "monthly_uvb_flux" ;
    qudt:unit qudt:W-PER-M2 ;
    rdfs:comment "月 UV-B 下行通量，健康风险和晴空辐射背景" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS1> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/monthly_uvb_clear_ratio> ;
    saudi:effectiveDays 365 ;
    saudi:expression "duvb" ;
    saudi:hasDAG "{\"op\": \"var\", \"name\": \"duvb\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/monthly_wind_stress_mag> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "monthly_wind_stress_mag" ;
    qudt:unit qudt:N-PER-M2 ;
    rdfs:comment "月地表风应力强度，反映地表动量交换" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS1> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/monthly_orographic_stress> ;
    saudi:effectiveDays 365 ;
    saudi:expression "sqrt(avg_utaua^2 + avg_vtaua^2)" ;
    saudi:hasDAG "{\"op\": \"sqrt\", \"left\": {\"op\": \"add\", \"left\": {\"op\": \"sqr\", \"left\": {\"op\": \"var\", \"name\": \"avg_utaua\"}}, \"right\": {\"op\": \"sqr\", \"left\": {\"op\": \"var\", \"name\": \"avg_vtaua\"}}}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/omega700> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "omega700" ;
    rdfs:comment "700 hPa垂直速度，负值表示上升运动" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/cape>,
        <https://mazu.cma/saudi#Indicator/omega500> ;
    saudi:effectiveDays 292 ;
    saudi:expression "omega at 700 hPa" ;
    saudi:hasDAG "{\"op\": \"var\", \"name\": \"omega700_raw\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/t2m_climatology_station_distance_km> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "t2m_climatology_station_distance_km" ;
    qudt:unit qudt:KiloM ;
    rdfs:comment "TAVG气候态最近站距离" ;
