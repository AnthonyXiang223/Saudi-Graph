    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/cape>,
        <https://mazu.cma/saudi#Indicator/daily_precip_total>,
        <https://mazu.cma/saudi#Indicator/ivt>,
        <https://mazu.cma/saudi#Indicator/ivt_convergence> ;
    saudi:effectiveDays 292 ;
    saudi:expression "pwat" ;
    saudi:hasDAG "{\"op\": \"var\", \"name\": \"pwat\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/wind10_speed> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "wind10_speed" ;
    qudt:unit qudt:M-PER-SEC ;
    rdfs:comment "10米风速" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/dewpoint_depression_c>,
        <https://mazu.cma/saudi#Indicator/flash_flood_risk>,
        <https://mazu.cma/saudi#Indicator/wind850_speed>,
        <https://mazu.cma/saudi#Indicator/wind925_speed> ;
    saudi:effectiveDays 364 ;
    saudi:expression "sqrt(u10^2 + v10^2)" ;
    saudi:hasDAG "{\"op\": \"sqrt\", \"left\": {\"op\": \"add\", \"left\": {\"op\": \"sqr\", \"left\": {\"op\": \"var\", \"name\": \"u10\"}}, \"right\": {\"op\": \"sqr\", \"left\": {\"op\": \"var\", \"name\": \"v10\"}}}}" ;
    saudi:totalDays 365 .

