    saudi:effectiveDays 291 ;
    saudi:expression "sqrt(u925^2 + v925^2)" ;
    saudi:hasDAG "{\"op\": \"sqrt\", \"left\": {\"op\": \"add\", \"left\": {\"op\": \"sqr\", \"left\": {\"op\": \"var\", \"name\": \"u925\"}}, \"right\": {\"op\": \"sqr\", \"left\": {\"op\": \"var\", \"name\": \"v925\"}}}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/wind_shear_850_300> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "wind_shear_850_300" ;
    qudt:unit qudt:M-PER-SEC ;
    rdfs:comment "850-300 hPa垂直风切变，强对流组织化条件" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/cape>,
        <https://mazu.cma/saudi#Indicator/wind_shear_850_200> ;
    saudi:effectiveDays 291 ;
    saudi:expression "sqrt((u300-u850)^2 + (v300-v850)^2)" ;
    saudi:hasDAG "{\"op\": \"sqrt\", \"left\": {\"op\": \"add\", \"left\": {\"op\": \"sqr\", \"left\": {\"op\": \"sub\", \"left\": {\"op\": \"var\", \"name\": \"u300\"}, \"right\": {\"op\": \"var\", \"name\": \"u850\"}}}, \"right\": {\"op\": \"sqr\", \"left\": {\"op\": \"sub\", \"left\": {\"op\": \"var\", \"name\": \"v300\"}, \"right\": {\"op\": \"var\", \"name\": \"v850\"}}}}}" ;
    saudi:totalDays 365 .

hip1:HC07 a owl:Class ;
    rdfs:label "Food Safety" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:CH ],
        hip1:HazardCluster .

hip1:HC08 a owl:Class ;
    rdfs:label "Infectious Disease (Plant)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        hip1:HazardCluster .

hip1:HC10 a owl:Class ;
    rdfs:label "Infectious Diseases (Animal)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        hip1:HazardCluster .

hip1:HC15 a owl:Class ;
    rdfs:label "Persistent Organic Pollutants (POPs)" ;
