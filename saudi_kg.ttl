hip1:BI0005 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0005 ;
    rdfs:label "Invasive Species" ;
    rdfs:subClassOf hip1:SpecificHazard ;
    hip1:identifier "BI0005" ;
    hip1:synonym "Alien invasive species",
        "Alien species",
        "Invasive alien species" .

hip1:BI0006 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0006 ;
    rdfs:label "Snake Envenomation" ;
    rdfs:subClassOf [ a owl:Restriction ;
