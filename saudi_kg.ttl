@prefix deo: <http://purl.org/disaster/deo#> .
@prefix deo1: <http://knowwheregraph/ontology/deo#> .
@prefix dpo: <http://purl.org/disaster/dpo#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix geof: <http://www.opengis.net/ont/geosparql#> .
@prefix hip: <http://purl.org/disaster/hip#> .
@prefix hip1: <https://undrr-hip.org/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix qudt: <http://qudt.org/schema/qudt#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix saudi: <https://mazu.cma/saudi#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix ssn: <http://www.w3.org/ns/ssn/> .
@prefix terms: <http://purl.org/dc/terms/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://aiknowspfas.skai.maine.edu/lod/ontology/definition.GH0004> a owl:NamedIndividual,
        hip1:Definition ;
    skos:definition """Earthquake surface ruptures and fissures are localised ground displacements that develop during and immediately after an earthquake, where the fault which hosted the earthquake intersects the Earth’s surface. Surface ruptures represent the upward continuation of fault slip at depth, while fissures are smaller displacements, or more distributed deformation in and around the rupture area (adapted from USGS, no date and PNSN, no date).\r
\r
Tectonic uplift and subsidence are the distributed vertical permanent ground deformations (warping) that result from displacement on a dipping (inclined) fault (Styron, 2019).""" ;
    hip1:definitionSource hip1:organization.gem .

<http://knowwheregraph/ontology/deo> a owl:Ontology ;
    terms:created "2024-04-23"^^xsd:date ;
    terms:creator [ a foaf:Agent ;
            foaf:name "The KnowWhereGraph Project"@en ] ;
    terms:description "The Disaster Event Ontology (DEO) conceptualizes disaster-related events, related observations, spatiotemporal aspects, and causal relations. This ontology is meant to link the HIP Ontology to other disaster-themed data."@en ;
    terms:license <https://creativecommons.org/licenses/by/4.0/> ;
    terms:title "Disaster Event Ontology (DEO)"@en ;
    vann:preferredNamespaceUri "http://knowwheregraph/ontology/deo/" ;
    owl:versionInfo "v 1.0" .

deo1:DisasterObservation a owl:Class ;
    rdfs:label "Disaster Observation" ;
    skos:description "This class denotes observations corresponding to instances of the Disaster class." .

deo1:HazardObservation a owl:Class ;
    rdfs:label "Hazard Observation" ;
    skos:description "This class denotes observations corresponding to instances of the Hazard class." .

deo1:HazardProperty a owl:Class ;
    rdfs:label "Hazard Property" ;
    skos:description "This class denotes the observable properties for any specific type of hazard. For e.g., the observable properties of a hurricane are sustained wind speed, atmospheric pressure." .

deo1:ImpactObservation a owl:Class ;
    rdfs:label "Impact Observation" ;
    skos:description "This class denotes observations corresponding to instances of the DisasterImpact class." .

deo1:ImpactType a owl:Class ;
    rdfs:label "Impact Type" ;
    skos:description "This concept refers to the impact theme or the ultimate feature of interest in SOSA terminology. This class denotes the impact types denotes in standard classification schemes, e.g., impact types from Desinventar." .

deo1:PossiblyCausesRelation a owl:Class ;
    rdfs:label "Possibly Causes Relation" ;
    skos:description "Reification of the possiblyCauses relation." .

deo1:hasDisasterOfInterest a owl:ObjectProperty ;
    rdfs:label "has disaster of Interest" ;
    schema1:domainIncludes "'Disaster Observation'" ;
    schema1:rangeIncludes "Disaster" .

deo1:hasHazardOfInterest a owl:ObjectProperty ;
    rdfs:label "has hazard of interest" ;
    schema1:domainIncludes "'Hazard Observation'" ;
    schema1:rangeIncludes "Hazard" .

deo1:hasHazardProperty a owl:ObjectProperty ;
    rdfs:label "has hazard property" ;
    schema1:domainIncludes "'Hazard Type'" ;
    schema1:rangeIncludes "'Hazard Property'" .

deo1:hasImpactOfInterest a owl:ObjectProperty ;
    rdfs:label "has impact of interest" ;
    schema1:domainIncludes "'Impact Observation'" ;
    schema1:rangeIncludes "'Disaster Impact'" .

deo1:hasPart a owl:ObjectProperty ;
    rdfs:label "has part" ;
    schema1:domainIncludes "Event" ;
    schema1:rangeIncludes "Event" .

deo1:hasTemporalScope a owl:ObjectProperty ;
    rdfs:label "has temporal scope" ;
    schema1:domainIncludes "Event" .

deo1:hasUltimateFeatureOfInterest a owl:ObjectProperty ;
    rdfs:label "has ultimate feature of interest" ;
    schema1:domainIncludes "'Disaster Observation'",
        "'Hazard Observation'" ;
    schema1:rangeIncludes "'Hazard Type'" .

deo1:impactType a owl:ObjectProperty ;
    rdfs:label "impact type" ;
    schema1:domainIncludes "'Disaster Impact'" ;
    schema1:rangeIncludes "'Impact Type'" .

deo1:involvedInImpact a owl:ObjectProperty ;
    rdfs:label "involved in impact" ;
    schema1:domainIncludes "Element-At-Risk" ;
    schema1:rangeIncludes "'Disaster Impact'" .

deo1:observedProperty a owl:ObjectProperty ;
    rdfs:label "observed property" ;
    schema1:domainIncludes "'Disaster Observation'",
        "'Hazard Observation'",
        "'Impact Observation'" ;
    schema1:rangeIncludes "'Hazard Property'",
        "'Impact Type'" .

deo1:relatedImpact a owl:ObjectProperty ;
    rdfs:label "related impact" ;
    schema1:domainIncludes "Disaster" ;
    schema1:rangeIncludes "'Disaster Impact'" ;
    rdfs:subPropertyOf deo1:possiblyCauses .

deo1:resultOf a owl:ObjectProperty ;
    rdfs:label "result of" ;
    schema1:domainIncludes "Disaster",
        "Hazard" ;
    schema1:rangeIncludes "Disaster",
        "Hazard" ;
    rdfs:subPropertyOf deo1:possiblyCauses .

<http://knowwheregraph/ontology/deo/Disaster> a owl:Class ;
    rdfs:label "Disaster" ;
    rdfs:subClassOf <http://knowwheregraph/ontology/deo/Hazard> ;
    skos:description "A serious disruption of the functioning of a community or a society at any scale due to hazardous events interacting with conditions of exposure, vulnerability and capacity, leading to one or more of the following: human, material, economic and environmental losses and impacts. The effect of the disaster can be immediate and localized, but is often widespread and could last for a long period of time. The effect may test or exceed the capacity of a community or society to cope using its own resources, and therefore may require assistance from external sources, which could include neighbouring jurisdictions, or those at the national or international levels. (Source: UNDRR Glossary - https://www.undrr.org/terminology)" .

<http://knowwheregraph/ontology/deo/DisasterImpact> a owl:Class ;
    rdfs:label "Disaster Impact" ;
    rdfs:subClassOf <http://knowwheregraph/ontology/deo/Event> ;
    skos:description "Disaster impact is the total effect, including negative effects (e.g., economic losses) and positive effects (e.g., economic gains), of a hazardous event or a disaster. The term includes economic, human and environmental impacts, and may include death, injuries, disease and other negative effects on human physical, mental and social well-being. (Source: UNDRR Glossary - https://www.undrr.org/terminology)" .

<http://knowwheregraph/ontology/deo/ElementAtRisk> a owl:Class ;
    rdfs:label "Element-At-Risk" ;
    skos:description "Element-at risk is a generic term that signifies all objects, persons, animals, activities and processes that may be adversely affected by hazardous phenomena, in a particular area, either directly or indirectly. This includes: buildings, facilities, population, livestock, economic activities, public services, environment. (Source: The Carribean Handbook of Risk Information Management http://www.charim.net/methodology/52)" .

<http://knowwheregraph/ontology/deo/HazardType> a owl:Class ;
    rdfs:label "Hazard Type" ;
    skos:description "This concept refers to the hazard theme or the ultimate feature of interest in SOSA terminology. This class denotes the hazard types denotes in standard classification schemes, e.g., the HIP Ontology." .

<http://knowwheregraph/ontology/deo/affectedBy> a owl:ObjectProperty ;
    rdfs:label "affected by" ;
    schema1:domainIncludes "Element-At-Risk" ;
    schema1:rangeIncludes "Disaster",
        "Hazard" .

<http://knowwheregraph/ontology/deo/hazardType> a owl:ObjectProperty ;
    rdfs:label "hazard type" ;
    schema1:domainIncludes "Disaster",
        "Hazard" ;
    schema1:rangeIncludes "'Hazard Type'" .

<http://knowwheregraph/ontology/dmdo/affectedBy> a owl:ObjectProperty ;
    rdfs:label "affected by" ;
    schema1:domainIncludes "Element-At-Risk" ;
    schema1:rangeIncludes "Disaster",
        "Hazard" .

<http://knowwheregraph/ontology/dmdo/hasSpatialExtent> a owl:ObjectProperty ;
    rdfs:label "has spatial extent" ;
    schema1:rangeIncludes geof:SpatialObject .

<http://knowwheregraph/ontology/dmdo/hasTemporalExtent> a owl:ObjectProperty ;
    rdfs:label "has temporal extent" ;
    schema1:rangeIncludes time:TemporalEntity .

<http://knowwheregraph/ontology/dmdo/hazardType> a owl:ObjectProperty ;
    rdfs:label "hazard type" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dmdo/Disaster>,
        <http://knowwheregraph/ontology/dmdo/Hazard> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dmdo/HazardType> .

<http://knowwheregraph/ontology/dmdo/involvedIn> a owl:ObjectProperty ;
    rdfs:label "involved in" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dmdo/ElementAtRisk> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dmdo/DisasterImpact> .

<http://knowwheregraph/ontology/dmdo/resultOf> a owl:ObjectProperty ;
    rdfs:label "result of" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dmdo/Disaster> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dmdo/Hazard> ;
    owl:inverseOf <http://knowwheregraph/ontology/dmdo/resultsIn> .

<http://knowwheregraph/ontology/dpo> a owl:Ontology ;
    terms:created "2023-05-11"^^xsd:date ;
    terms:creator [ a foaf:Agent ;
            foaf:name "The KnowWhereGraph Project"@en ] ;
    terms:description "This ontology is for modeling disaster management domain properties."@en ;
    terms:license <https://creativecommons.org/licenses/by/4.0/> ;
    terms:title "Disaster Properties Ontology (DPO)"@en ;
    vann:preferredNamespaceUri "http://knowwheregraph/ontology/dpo/" ;
    owl:versionInfo "v 1.0" .

<http://knowwheregraph/ontology/dpo/associatedWithDisaster> a owl:ObjectProperty ;
    rdfs:label "associated with disaster" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dpo/Vulnerability> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dmdo/Disaster> .

<http://knowwheregraph/ontology/dpo/associatedWithHazardType> a owl:ObjectProperty ;
    rdfs:label "associated with hazard type" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dpo/DisasterRisk>,
        <http://knowwheregraph/ontology/dpo/Vulnerability> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dmdo/HazardType> .

<http://knowwheregraph/ontology/dpo/capacityOfElementAtRisk> a owl:ObjectProperty ;
    rdfs:label "capacity of element-at-risk" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dpo/AdaptiveCapacity> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dmdo/ElementAtRisk> ;
    rdfs:subPropertyOf ssn:isPropertyOf ;
    owl:inverseOf <http://knowwheregraph/ontology/dpo/hasCapacity> .

<http://knowwheregraph/ontology/dpo/determinesImpact> a owl:ObjectProperty ;
    rdfs:label "determines impact" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dpo/Vulnerability> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dmdo/DisasterImpact> .

<http://knowwheregraph/ontology/dpo/determinesRisk> a owl:ObjectProperty ;
    rdfs:label "determines risk" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dpo/AdaptiveCapacity>,
        <http://knowwheregraph/ontology/dpo/Intensity>,
        <http://knowwheregraph/ontology/dpo/LevelOfExposure>,
        <http://knowwheregraph/ontology/dpo/Resilience>,
        <http://knowwheregraph/ontology/dpo/Vulnerability> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dpo/DisasterRisk> .

<http://knowwheregraph/ontology/dpo/exposureOfElementAtRisk> a owl:ObjectProperty ;
    rdfs:label "exposure of element-at-risk" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dpo/LevelOfExposure> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dmdo/ElementAtRisk> ;
    rdfs:subPropertyOf ssn:isPropertyOf ;
    owl:inverseOf <http://knowwheregraph/ontology/dpo/hasExposure> .

<http://knowwheregraph/ontology/dpo/hasDisasterRisk> a owl:ObjectProperty ;
    rdfs:label "has disaster risk" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dmdo/ElementAtRisk> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dpo/DisasterRisk> ;
    rdfs:subPropertyOf ssn:hasProperty ;
    owl:inverseOf <http://knowwheregraph/ontology/dpo/riskOfElementAtRisk> .

<http://knowwheregraph/ontology/dpo/hasExpectedImpact> a owl:ObjectProperty ;
    rdfs:label "has expected impact" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dpo/DisasterRisk> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dmdo/DisasterImpact> .

<http://knowwheregraph/ontology/dpo/hasIntensity> a owl:ObjectProperty ;
    rdfs:label "has intensity" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dmdo/Disaster> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dpo/Intensity> ;
    rdfs:subPropertyOf ssn:hasProperty ;
    owl:inverseOf <http://knowwheregraph/ontology/dpo/intensityOfDisaster> .

<http://knowwheregraph/ontology/dpo/hasResilience> a owl:ObjectProperty ;
    rdfs:label "has resilience" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dmdo/ElementAtRisk> ;
    schema1:rangeIncludes <http://knowwheregraph/ontology/dpo/Resilience> ;
    rdfs:subPropertyOf ssn:hasProperty ;
    owl:inverseOf <http://knowwheregraph/ontology/dpo/resilienceOfElementAtRisk> .

<http://knowwheregraph/ontology/dpo/hasSeverity> a owl:ObjectProperty ;
    rdfs:label "has severity" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dmdo/DisasterImpact>,
        <http://knowwheregraph/ontology/dpo/Severity> ;
    rdfs:subPropertyOf ssn:hasProperty ;
    owl:inverseOf <http://knowwheregraph/ontology/dpo/severityOfImpact> .

<http://knowwheregraph/ontology/dpo/hasVulnerability> a owl:ObjectProperty ;
    rdfs:label "has vulnerability" ;
    schema1:domainIncludes <http://knowwheregraph/ontology/dmdo/ElementAtRisk>,
        <http://knowwheregraph/ontology/dpo/Vulnerability> ;
    rdfs:subPropertyOf ssn:hasProperty ;
    owl:inverseOf <http://knowwheregraph/ontology/dpo/vulnerabilityOfElementAtRisk> .

<http://knowwheregraph/ontology/dpo/riskLevel> a owl:DatatypeProperty ;
    rdfs:label "level of risk" .

<http://knowwheregraph/ontology/dpo/riskProbability> a owl:DatatypeProperty ;
    rdfs:label "risk probability" .

<http://knowwheregraph/ontology/dpo/uncertainty> a owl:DatatypeProperty ;
    rdfs:label "uncertainty of risk" .

terms:contributor a owl:AnnotationProperty .

terms:created a owl:AnnotationProperty .

terms:creator a owl:AnnotationProperty .

terms:date a owl:AnnotationProperty .

terms:description a owl:AnnotationProperty .

terms:license a owl:AnnotationProperty .

terms:references a owl:AnnotationProperty .

terms:rights a owl:AnnotationProperty .

terms:source a owl:AnnotationProperty .

terms:title a owl:AnnotationProperty .

vann:preferredNamespacePrefix a owl:AnnotationProperty .

vann:preferredNamespaceUri a owl:AnnotationProperty .

schema1:domainIncludes a owl:AnnotationProperty .

schema1:rangeIncludes a owl:AnnotationProperty .

xsd:gYear a rdfs:Datatype .

skos:altLabel a owl:AnnotationProperty .

skos:definition a owl:AnnotationProperty .

skos:description a owl:AnnotationProperty .

skos:editorialNote a owl:AnnotationProperty .

skos:example a owl:AnnotationProperty .

skos:note a owl:AnnotationProperty .

skos:prefLabel a owl:AnnotationProperty .

foaf:name a owl:AnnotationProperty .

<https://mazu.cma/saudi#Hazard/coastal_humid_heat_weighted> a deo:Hazard ;
    rdfs:label "coastal_humid_heat_weighted" ;
    deo:hasHazardProperty <https://mazu.cma/saudi#Indicator/heat_index_c>,
        <https://mazu.cma/saudi#Indicator/rh2m>,
        <https://mazu.cma/saudi#Indicator/sst_celsius>,
        <https://mazu.cma/saudi#Indicator/t2m_c> ;
    deo:hazardType <https://mazu.cma/saudi#HazardType/coastal_humid_heat> ;
    saudi:hasCondition [ a saudi:DetectionCondition ;
            saudi:comparisonOp ">=" ;
            saudi:isPrimary true ;
            saudi:threshold "30"^^xsd:float ;
            saudi:weight "0.3"^^xsd:float ],
        [ a saudi:DetectionCondition ;
            saudi:comparisonOp ">=" ;
            saudi:isPrimary false ;
            saudi:threshold "35"^^xsd:float ;
            saudi:weight "0.25"^^xsd:float ],
        [ a saudi:DetectionCondition ;
            saudi:comparisonOp ">=" ;
            saudi:isPrimary false ;
            saudi:threshold "30"^^xsd:float ;
            saudi:weight "0.15"^^xsd:float ],
        [ a saudi:DetectionCondition ;
            saudi:comparisonOp ">=" ;
            saudi:isPrimary false ;
            saudi:threshold "60"^^xsd:float ;
            saudi:weight "0.3"^^xsd:float ] ;
    saudi:hasSeverityLevel [ a saudi:SeverityLevel ;
            saudi:lowerBound "0.8"^^xsd:float ;
            saudi:severityLabel "emergency" ;
            saudi:upperBound "1.0"^^xsd:float ],
        [ a saudi:SeverityLevel ;
            saudi:lowerBound "0.0"^^xsd:float ;
            saudi:severityLabel "caution" ;
            saudi:upperBound "0.3"^^xsd:float ],
        [ a saudi:SeverityLevel ;
            saudi:lowerBound "0.6"^^xsd:float ;
            saudi:severityLabel "alert" ;
            saudi:upperBound "0.8"^^xsd:float ],
        [ a saudi:SeverityLevel ;
            saudi:lowerBound "0.3"^^xsd:float ;
            saudi:severityLabel "warning" ;
            saudi:upperBound "0.6"^^xsd:float ] .

<https://mazu.cma/saudi#Hazard/dust_storm_weighted> a deo:Hazard ;
    rdfs:label "dust_storm_weighted" ;
    deo:hasHazardProperty <https://mazu.cma/saudi#Indicator/dewpoint_depression_c>,
        <https://mazu.cma/saudi#Indicator/rh2m>,
        <https://mazu.cma/saudi#Indicator/wind10_speed>,
        <https://mazu.cma/saudi#Indicator/wind_shear_850_200> ;
    deo:hazardType <https://mazu.cma/saudi#HazardType/dust_storm> ;
    saudi:hasCondition [ a saudi:DetectionCondition ;
            saudi:comparisonOp "<" ;
            saudi:isPrimary false ;
            saudi:threshold "25"^^xsd:float ;
            saudi:weight "0.25"^^xsd:float ],
        [ a saudi:DetectionCondition ;
            saudi:comparisonOp ">=" ;
            saudi:isPrimary false ;
            saudi:threshold "30"^^xsd:float ;
            saudi:weight "0.15"^^xsd:float ],
        [ a saudi:DetectionCondition ;
            saudi:comparisonOp ">=" ;
            saudi:isPrimary false ;
            saudi:threshold "20"^^xsd:float ;
            saudi:weight "0.25"^^xsd:float ],
        [ a saudi:DetectionCondition ;
            saudi:comparisonOp ">=" ;
            saudi:isPrimary true ;
            saudi:threshold "12"^^xsd:float ;
            saudi:weight "0.35"^^xsd:float ] ;
    saudi:hasFallback [ a saudi:FallbackStrategy ;
            saudi:confidencePenalty "0.1"^^xsd:float ;
            saudi:missingIndicator "wind_shear_850_200" ;
            saudi:strategy "drop_condition" ] ;
    saudi:hasSeverityLevel [ a saudi:SeverityLevel ;
            saudi:lowerBound "0.8"^^xsd:float ;
            saudi:severityLabel "severe" ;
            saudi:upperBound "1.0"^^xsd:float ],
        [ a saudi:SeverityLevel ;
            saudi:lowerBound "0.0"^^xsd:float ;
            saudi:severityLabel "low" ;
            saudi:upperBound "0.3"^^xsd:float ],
        [ a saudi:SeverityLevel ;
            saudi:lowerBound "0.3"^^xsd:float ;
            saudi:severityLabel "moderate" ;
            saudi:upperBound "0.6"^^xsd:float ],
        [ a saudi:SeverityLevel ;
            saudi:lowerBound "0.6"^^xsd:float ;
            saudi:severityLabel "high" ;
            saudi:upperBound "0.8"^^xsd:float ] .

<https://mazu.cma/saudi#Hazard/extreme_heat_weighted> a deo:Hazard ;
    rdfs:label "extreme_heat_weighted" ;
    deo:hasHazardProperty <https://mazu.cma/saudi#Indicator/heat_index_c>,
        <https://mazu.cma/saudi#Indicator/heatwave_day_flag>,
        <https://mazu.cma/saudi#Indicator/heatwave_duration_days>,
        <https://mazu.cma/saudi#Indicator/tmax_c> ;
    deo:hazardType <https://mazu.cma/saudi#HazardType/extreme_heat> ;
    saudi:hasCondition [ a saudi:DetectionCondition ;
            saudi:comparisonOp ">=" ;
            saudi:isPrimary false ;
            saudi:threshold "45"^^xsd:float ;
            saudi:weight "0.25"^^xsd:float ],
        [ a saudi:DetectionCondition ;
            saudi:comparisonOp ">=" ;
            saudi:isPrimary true ;
            saudi:threshold "1"^^xsd:float ;
            saudi:weight "0.3"^^xsd:float ],
        [ a saudi:DetectionCondition ;
            saudi:comparisonOp ">=" ;
            saudi:isPrimary false ;
            saudi:threshold "3"^^xsd:float ;
            saudi:weight "0.3"^^xsd:float ],
        [ a saudi:DetectionCondition ;
            saudi:comparisonOp ">=" ;
            saudi:isPrimary false ;
            saudi:threshold "40"^^xsd:float ;
            saudi:weight "0.15"^^xsd:float ] ;
    saudi:hasSeverityLevel [ a saudi:SeverityLevel ;
            saudi:lowerBound "0.6"^^xsd:float ;
            saudi:severityLabel "alert" ;
            saudi:upperBound "0.8"^^xsd:float ],
        [ a saudi:SeverityLevel ;
            saudi:lowerBound "0.8"^^xsd:float ;
            saudi:severityLabel "emergency" ;
            saudi:upperBound "1.0"^^xsd:float ],
        [ a saudi:SeverityLevel ;
            saudi:lowerBound "0.3"^^xsd:float ;
            saudi:severityLabel "warning" ;
            saudi:upperBound "0.6"^^xsd:float ],
        [ a saudi:SeverityLevel ;
            saudi:lowerBound "0.0"^^xsd:float ;
            saudi:severityLabel "caution" ;
            saudi:upperBound "0.3"^^xsd:float ] .

<https://mazu.cma/saudi#Hazard/flash_flood_weighted> a deo:Hazard ;
    rdfs:label "flash_flood_weighted" ;
    deo:hasHazardProperty <https://mazu.cma/saudi#Indicator/cape>,
        <https://mazu.cma/saudi#Indicator/daily_precip_total>,
        <https://mazu.cma/saudi#Indicator/ds10_max_1h>,
        <https://mazu.cma/saudi#Indicator/flash_flood_risk>,
        <https://mazu.cma/saudi#Indicator/ivt_convergence> ;
    deo:hazardType <https://mazu.cma/saudi#HazardType/flash_flood> ;
    saudi:hasCondition [ a saudi:DetectionCondition ;
            saudi:comparisonOp ">" ;
            saudi:isPrimary false ;
            saudi:threshold "0"^^xsd:float ;
            saudi:weight "0.1"^^xsd:float ],
        [ a saudi:DetectionCondition ;
            saudi:comparisonOp ">=" ;
            saudi:isPrimary false ;
            saudi:threshold "10"^^xsd:float ;
            saudi:weight "0.15"^^xsd:float ],
        [ a saudi:DetectionCondition ;
            saudi:comparisonOp ">=" ;
            saudi:isPrimary true ;
            saudi:threshold "3"^^xsd:float ;
            saudi:weight "0.3"^^xsd:float ],
        [ a saudi:DetectionCondition ;
            saudi:comparisonOp ">=" ;
            saudi:isPrimary false ;
            saudi:threshold "1000"^^xsd:float ;
            saudi:weight "0.2"^^xsd:float ],
        [ a saudi:DetectionCondition ;
            saudi:comparisonOp ">=" ;
            saudi:isPrimary false ;
            saudi:threshold "10"^^xsd:float ;
            saudi:weight "0.25"^^xsd:float ] ;
    saudi:hasFallback [ a saudi:FallbackStrategy ;
            saudi:confidencePenalty "0.15"^^xsd:float ;
            saudi:missingIndicator "ds10_max_1h" ;
            saudi:strategy "drop_condition" ] ;
    saudi:hasSeverityLevel [ a saudi:SeverityLevel ;
            saudi:lowerBound "0.6"^^xsd:float ;
            saudi:severityLabel "high" ;
            saudi:upperBound "0.8"^^xsd:float ],
        [ a saudi:SeverityLevel ;
            saudi:lowerBound "0.3"^^xsd:float ;
            saudi:severityLabel "medium" ;
            saudi:upperBound "0.6"^^xsd:float ],
        [ a saudi:SeverityLevel ;
            saudi:lowerBound "0.8"^^xsd:float ;
            saudi:severityLabel "extreme" ;
            saudi:upperBound "1.0"^^xsd:float ],
        [ a saudi:SeverityLevel ;
            saudi:lowerBound "0.0"^^xsd:float ;
            saudi:severityLabel "low" ;
            saudi:upperBound "0.3"^^xsd:float ] .

<https://mazu.cma/saudi#Indicator/ds10_rainy_steps> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "ds10_rainy_steps" ;
    rdfs:comment "DS10有雨时次数，表示日内降水持续性" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS10> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/ds10_daily_total> ;
    saudi:effectiveDays 273 ;
    saudi:expression "rainy_steps, 最近邻重采样" ;
    saudi:hasDAG "{\"op\": \"nearest_resample\", \"var\": \"ds10_rainy_steps_raw\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/orography> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "orography" ;
    rdfs:comment "地形高度(静态)，用于解释山地抬升和降水空间分布" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/monthly_orographic_stress>,
        <https://mazu.cma/saudi#Indicator/surface_pressure> ;
    saudi:effectiveDays 292 ;
    saudi:expression "orog" ;
    saudi:hasDAG "{\"op\": \"var\", \"name\": \"orog\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/precip_mmday> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "precip_mmday" ;
    qudt:unit qudt:MilliM-PER-DAY ;
    rdfs:comment "日平均降水率换算，来自日平均降水率 prate * 86400" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/daily_precip_total> ;
    saudi:effectiveDays 2 ;
    saudi:expression "prate * 86400" ;
    saudi:hasDAG "{\"op\": \"mul\", \"left\": {\"op\": \"var\", \"name\": \"prate\"}, \"right\": 86400}" ;
    saudi:totalDays 365 .

