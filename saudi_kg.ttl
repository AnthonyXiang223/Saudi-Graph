            owl:someValuesFrom hip1:HC09 ],
        hip1:SpecificHazard ;
    skos:definition "Animal trypanosomosis is a lethal parasitic disease caused by unicellular organisms named trypanosomes. The disease is cyclically transmitted by the bite of infected tsetse flies and it affects both humans ‘sleeping sickness’ and livestock ‘nagana’ (FAO, 2020)." .

hip1:BI0084 a owl:Class,
        owl:NamedIndividual,
