hip1:BI00869 a owl:Class,
        owl:NamedIndividual,
        hip1:BI00869 ;
    rdfs:label "Trypanosomiasis (Human)" ;
    rdfs:comment "Trypanosomiasis, human African (sleeping sickness) is caused by protozoan parasites belonging to the genus Trypanosoma transmitted by infected tsetse flies and is endemic in 36 sub-Saharan African countries. Without treatment, the disease is considered fatal, where there are tsetse flies that transmit the disease (WHO, 2020)." ;
    rdfs:subClassOf [ a owl:Restriction ;
