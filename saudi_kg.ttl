hip1:organization.unesco a owl:NamedIndividual,
        hip1:Organization .

<https://mazu.cma/saudi#Indicator/ds10_daily_total> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "ds10_daily_total" ;
    qudt:unit qudt:MilliM ;
    rdfs:comment "DS10卫星日降水，最近邻对齐到指标网格" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS10> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/daily_precip_total>,
        <https://mazu.cma/saudi#Indicator/ds10_ds2_precip_diff>,
        <https://mazu.cma/saudi#Indicator/ds10_ds2_precip_ratio>,
        <https://mazu.cma/saudi#Indicator/ds10_max_1h>,
        <https://mazu.cma/saudi#Indicator/ds10_max_3h> ;
    saudi:effectiveDays 273 ;
    saudi:expression "daily_total, 最近邻重采样" ;
    saudi:hasDAG "{\"op\": \"nearest_resample\", \"var\": \"ds10_daily_total_raw\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/ivt> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "ivt" ;
    qudt:unit qudt:KiloGM-PER-M-SEC ;
    rdfs:comment "整层水汽输送强度，强水汽通道识别" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2>,
        <https://mazu.cma/saudi#Indicator/ivt_u>,
        <https://mazu.cma/saudi#Indicator/ivt_v> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/ivt_convergence>,
        <https://mazu.cma/saudi#Indicator/ivt_u>,
        <https://mazu.cma/saudi#Indicator/ivt_v>,
        <https://mazu.cma/saudi#Indicator/pwat> ;
    saudi:effectiveDays 291 ;
    saudi:expression "sqrt(ivt_u^2 + ivt_v^2)" ;
    saudi:hasDAG "{\"op\": \"sqrt\", \"left\": {\"op\": \"add\", \"left\": {\"op\": \"sqr\", \"left\": {\"op\": \"var\", \"name\": \"ivt_u\"}}, \"right\": {\"op\": \"sqr\", \"left\": {\"op\": \"var\", \"name\": \"ivt_v\"}}}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/ivt_u> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "ivt_u" ;
    qudt:unit qudt:KiloGM-PER-M-SEC ;
    rdfs:comment "整层水汽输送纬向分量，正值偏东向输送" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/ivt>,
        <https://mazu.cma/saudi#Indicator/ivt_v> ;
    saudi:effectiveDays 291 ;
    saudi:expression "1/g * integral(q*u dp)" ;
    saudi:hasDAG "{\"op\": \"ivt_component\", \"direction\": \"u\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/ivt_v> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "ivt_v" ;
    qudt:unit qudt:KiloGM-PER-M-SEC ;
    rdfs:comment "整层水汽输送经向分量，正值偏北向输送" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/ivt>,
        <https://mazu.cma/saudi#Indicator/ivt_u> ;
    saudi:effectiveDays 291 ;
    saudi:expression "1/g * integral(q*v dp)" ;
    saudi:hasDAG "{\"op\": \"ivt_component\", \"direction\": \"v\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/monthly_convective_precip> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "monthly_convective_precip" ;
    qudt:unit qudt:MilliM ;
    rdfs:comment "月累计对流降水，来自 DS1 MONTH_ACC acpcp" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS1> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/monthly_convective_precip_ratio>,
        <https://mazu.cma/saudi#Indicator/monthly_large_scale_precip> ;
    saudi:effectiveDays 365 ;
    saudi:expression "acpcp (MONTH_ACC)" ;
    saudi:hasDAG "{\"op\": \"var\", \"name\": \"acpcp\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/tmax_anomaly_c> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "tmax_anomaly_c" ;
    qudt:unit qudt:DegreeCelsius ;
    rdfs:comment "日最高温距平，正值表示最高温偏暖" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS4>,
        <https://mazu.cma/saudi#DataSource/DS8>,
        <https://mazu.cma/saudi#Indicator/tmax_c>,
        <https://mazu.cma/saudi#Indicator/tmax_climatology_c> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/heatwave_day_flag>,
        <https://mazu.cma/saudi#Indicator/t2m_anomaly_c>,
        <https://mazu.cma/saudi#Indicator/tmax_c> ;
    saudi:effectiveDays 363 ;
    saudi:expression "tmax_c - tmax_climatology_c" ;
    saudi:hasDAG "{\"op\": \"sub\", \"left\": {\"op\": \"var\", \"name\": \"tmax_c\"}, \"right\": {\"op\": \"var\", \"name\": \"tmax_climatology_c\"}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/tmin_c> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "tmin_c" ;
    qudt:unit qudt:DegreeCelsius ;
    rdfs:comment "日最低2米气温，夜间热胁迫参考" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS4> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/diurnal_temp_range_c>,
        <https://mazu.cma/saudi#Indicator/t2m_c>,
        <https://mazu.cma/saudi#Indicator/tmax_c> ;
    saudi:effectiveDays 363 ;
    saudi:expression "tmin - 273.15" ;
    saudi:hasDAG "{\"op\": \"sub\", \"left\": {\"op\": \"var\", \"name\": \"tmin\"}, \"right\": 273.15}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/vpd_kpa> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "vpd_kpa" ;
    qudt:unit qudt:KiloPA ;
    rdfs:comment "饱和水汽压差，越高空气越干蒸散需求越强" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2>,
        <https://mazu.cma/saudi#Indicator/rh2m>,
        <https://mazu.cma/saudi#Indicator/t2m_c> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/bowen_ratio>,
        <https://mazu.cma/saudi#Indicator/dewpoint_depression_c>,
        <https://mazu.cma/saudi#Indicator/heat_index_c> ;
    saudi:effectiveDays 362 ;
    saudi:expression "es(T) * (1 - RH/100)" ;
    saudi:hasDAG "{\"op\": \"vpd_formula\", \"t_var\": \"t2m_c\", \"rh_var\": \"rh2m\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/wind_shear_850_200> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "wind_shear_850_200" ;
    qudt:unit qudt:M-PER-SEC ;
    rdfs:comment "850-200 hPa垂直风切变，深层风切变" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/jet200_speed>,
        <https://mazu.cma/saudi#Indicator/wind_shear_850_300> ;
    saudi:effectiveDays 291 ;
    saudi:expression "sqrt((u200-u850)^2 + (v200-v850)^2)" ;
    saudi:hasDAG "{\"op\": \"sqrt\", \"left\": {\"op\": \"add\", \"left\": {\"op\": \"sqr\", \"left\": {\"op\": \"sub\", \"left\": {\"op\": \"var\", \"name\": \"u200\"}, \"right\": {\"op\": \"var\", \"name\": \"u850\"}}}, \"right\": {\"op\": \"sqr\", \"left\": {\"op\": \"sub\", \"left\": {\"op\": \"var\", \"name\": \"v200\"}, \"right\": {\"op\": \"var\", \"name\": \"v850\"}}}}}" ;
    saudi:totalDays 365 .

