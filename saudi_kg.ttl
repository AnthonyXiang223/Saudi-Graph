<https://mazu.cma/saudi#Indicator/diurnal_temp_range_c> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "diurnal_temp_range_c" ;
    qudt:unit qudt:DegreeCelsius ;
