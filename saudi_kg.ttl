    saudi:hasDAG "{\"op\": \"var\", \"name\": \"gh500\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/heatwave_duration_days> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "heatwave_duration_days" ;
    qudt:unit qudt:Day ;
    rdfs:comment "热浪持续天数" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS4>,
        <https://mazu.cma/saudi#DataSource/DS8>,
        <https://mazu.cma/saudi#Indicator/heatwave_day_flag> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/heatwave_day_flag>,
        <https://mazu.cma/saudi#Indicator/tmax_c> ;
    saudi:effectiveDays 363 ;
    saudi:expression "对 heatwave_day_flag>=1 逐格逐日连续计数" ;
    saudi:hasDAG "{\"op\": \"consecutive_count\", \"flag_var\": \"heatwave_day_flag\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/ivt_divergence> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "ivt_divergence" ;
    qudt:unit qudt:KiloGM-PER-M2-SEC ;
    rdfs:comment "水汽输送散度，正值代表水汽发散" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2>,
        <https://mazu.cma/saudi#Indicator/ivt_u>,
        <https://mazu.cma/saudi#Indicator/ivt_v> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/ivt_convergence> ;
    saudi:effectiveDays 291 ;
    saudi:expression "d(ivt_u)/dx + d(ivt_v)/dy" ;
    saudi:hasDAG "{\"op\": \"spatial_divergence\", \"u_var\": \"ivt_u\", \"v_var\": \"ivt_v\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/jet200_speed> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "jet200_speed" ;
    qudt:unit qudt:M-PER-SEC ;
    rdfs:comment "200 hPa风速，副热带急流和高空动力" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/jet300_speed>,
        <https://mazu.cma/saudi#Indicator/wind_shear_850_200> ;
    saudi:effectiveDays 292 ;
    saudi:expression "sqrt(u200^2 + v200^2)" ;
    saudi:hasDAG "{\"op\": \"sqrt\", \"left\": {\"op\": \"add\", \"left\": {\"op\": \"sqr\", \"left\": {\"op\": \"var\", \"name\": \"u200\"}}, \"right\": {\"op\": \"sqr\", \"left\": {\"op\": \"var\", \"name\": \"v200\"}}}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/monthly_large_scale_precip> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "monthly_large_scale_precip" ;
    qudt:unit qudt:MilliM ;
    rdfs:comment "月累计非对流(层状/大尺度)降水，来自 DS1 MONTH_ACC ncpcp" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS1> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/monthly_convective_precip> ;
    saudi:effectiveDays 365 ;
    saudi:expression "ncpcp (MONTH_ACC)" ;
    saudi:hasDAG "{\"op\": \"var\", \"name\": \"ncpcp\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/monthly_net_radiation> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "monthly_net_radiation" ;
    qudt:unit qudt:W-PER-M2 ;
    rdfs:comment "月净辐射，地表能量收支背景" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS1>,
        <https://mazu.cma/saudi#Indicator/monthly_lw_net>,
        <https://mazu.cma/saudi#Indicator/monthly_sw_net> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/monthly_lw_net>,
        <https://mazu.cma/saudi#Indicator/monthly_sw_net> ;
    saudi:effectiveDays 365 ;
    saudi:expression "monthly_sw_net + monthly_lw_net" ;
    saudi:hasDAG "{\"op\": \"add\", \"left\": {\"op\": \"var\", \"name\": \"monthly_sw_net\"}, \"right\": {\"op\": \"var\", \"name\": \"monthly_lw_net\"}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/monthly_orographic_stress> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "monthly_orographic_stress" ;
    qudt:unit qudt:N-PER-M2 ;
    rdfs:comment "月地形重力波应力，表征地形扰动和山地动力作用" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS1> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/monthly_wind_stress_mag> ;
    saudi:effectiveDays 365 ;
    saudi:expression "sqrt(iegwss^2 + ingwss^2)" ;
    saudi:hasDAG "{\"op\": \"sqrt\", \"left\": {\"op\": \"add\", \"left\": {\"op\": \"sqr\", \"left\": {\"op\": \"var\", \"name\": \"iegwss\"}}, \"right\": {\"op\": \"sqr\", \"left\": {\"op\": \"var\", \"name\": \"ingwss\"}}}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/net_radiation> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "net_radiation" ;
    qudt:unit qudt:W-PER-M2 ;
    rdfs:comment "日净辐射，地表可用能量" ;
