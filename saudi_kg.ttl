    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/qmin_2m>,
        <https://mazu.cma/saudi#Indicator/sh2m> ;
    saudi:effectiveDays 363 ;
    saudi:expression "qmax" ;
    saudi:hasDAG "{\"op\": \"var\", \"name\": \"qmax\"}" ;
