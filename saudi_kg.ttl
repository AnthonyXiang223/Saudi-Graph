    saudi:totalDays 365 .

hip1:BI0001 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0001 ;
    rdfs:label "Harmful Algal Blooms" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC01 ],
        hip1:SpecificHazard ;
    hip1:identifier "BI0001" ;
    hip1:synonym "HABs" .

hip1:BI0002 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0002 ;
    rdfs:label "Insect Pest Infestations" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC02 ],
        hip1:SpecificHazard ;
    hip1:identifier "BI0002" ;
    hip1:synonym "Invasion Swarm Plague",
        "Outbreak" .

hip1:BI0003 a owl:Class,
        owl:NamedIndividual,
