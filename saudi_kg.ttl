    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/t2m_climatology_c> ;
    saudi:effectiveDays 364 ;
    saudi:expression "网格点到所用 DS8 TAVG 站的球面距离" ;
    saudi:hasDAG "{\"op\": \"ds8_station_distance\", \"element\": \"TAVG\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/tmax_climatology_station_distance_km> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "tmax_climatology_station_distance_km" ;
