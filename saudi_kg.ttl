hip1:GH0035 a owl:Class,
        owl:NamedIndividual,
        hip1:GH0035 ;
    rdfs:label "Tsunami (Submarine Landslide Trigger)" ;
    terms:references "https://unesdoc.unesco.org/ark:/48223/pf0000188226?posInSet=1&queryId=aeb846ae-edfb-4d66-a03a-385a5d5897f0" ;
    rdfs:subClassOf hip1:SpecificHazard ;
    skos:definition "Tsunami is a Japanese term meaning wave (‘nami’) in a harbour (‘tsu’). It is a series of travelling waves of extremely long length and period. They are usually generated by seabed disturbances associated with earthquakes occurring below or near the ocean floor, but also by other mechanisms such as submarine landslides (IOC, 2019)." ;
    hip1:definitionSource hip1:organization.unesco .

hip1:GHC041 a owl:Class,
        owl:NamedIndividual,
        hip1:GHC041 ;
    rdfs:label "Submarine Landslide" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:GH ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC23 ],
        hip1:SpecificHazard ;
    skos:definition "A submarine landslide is a downslope movement of sediment or rock under the effect of gravity, which occurs when the stresses acting downslope exceed the available strength of the sediment on the slope (Lee et al., 2007)." .

hip1:GHC042 a owl:Class,
        owl:NamedIndividual,
        hip1:GHC042 ;
    rdfs:label "Rockfall" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:GH ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC23 ],
        hip1:SpecificHazard ;
    skos:definition "Rockfall is a fragment of rock (a block) detached by sliding, toppling, or falling, that falls along a vertical or sub-vertical cliff, and proceeds down slope by bouncing and flying along ballistic trajectories or by rolling on talus or debris slopes (Highland and Bobrowsky, 2008)." .

hip1:GHC043 a owl:Class,
        owl:NamedIndividual,
        hip1:GHC043 ;
    rdfs:label "Landscape Creep" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:GH ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC23 ],
        hip1:SpecificHazard ;
    skos:definition "Landscape creep is the imperceptibly slow, steady, downward movement of slope-forming soil or rock. Movement is caused by shear stress, sufficient to produce permanent deformation, but too small to produce shear failure (adapted from Hutchinson, 1968; and Varnes, 1978)." .

hip1:GHC044 a owl:Class,
        owl:NamedIndividual,
        hip1:GHC044 ;
    rdfs:label "Sediment Rock Avalanche" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:GH ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC23 ],
        hip1:SpecificHazard ;
    skos:definition "Rock avalanches are a translational form of mass movement where the transported material is dry rock that is fragmented before or during slope failure. They are rapid with long runouts and large volumes and often involve the entrainment of slope material, commonly therefore, giving rise to debris slides or flows. The motion of rock avalanches is massive such that the bulk of the rock fragments move together as a largely coherent mass (adapted from Collins, 2014 and USGS, no date)." .

hip1:GHC045 a owl:Class,
        owl:NamedIndividual,
        hip1:GHC045 ;
    rdfs:label "Tsunami (Submarine Landslide Trigger)" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:GH ],
        [ a owl:Restriction ;
            owl:onProperty hip1:isMemberOf ;
            owl:someValuesFrom hip1:HC23 ],
        hip1:SpecificHazard ;
    skos:definition "Tsunami is a Japanese term meaning wave (‘nami’) in a harbour (‘tsu’). It is a series of travelling waves of extremely long length and period. They are usually generated by seabed disturbances associated with earthquakes occurring below or near the ocean floor, but also by other mechanisms such as submarine landslides (IOC, 2019)." .

