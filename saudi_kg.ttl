    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/lw_net>,
        <https://mazu.cma/saudi#Indicator/sw_net> ;
    saudi:effectiveDays 364 ;
    saudi:expression "sw_net + lw_net" ;
    saudi:hasDAG "{\"op\": \"add\", \"left\": {\"op\": \"var\", \"name\": \"sw_net\"}, \"right\": {\"op\": \"var\", \"name\": \"lw_net\"}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/omega500> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "omega500" ;
    rdfs:comment "500 hPa垂直速度，中层上升/下沉运动" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
