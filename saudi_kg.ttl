<http://knowwheregraph/ontology/dmdo/Disaster> a owl:Class ;
    rdfs:label "Disaster" ;
    rdfs:comment "A serious disruption of the functioning of a community or a society at any scale due to hazardous events interacting with conditions of exposure, vulnerability and capacity, leading to one or more of the following: human, material, economic and environmental losses and impacts. The effect of the disaster can be immediate and localized, but is often widespread and could last for a long period of time. The effect may test or exceed the capacity of a community or society to cope using its own resources, and therefore may require assistance from external sources, which could include neighbouring jurisdictions, or those at the national or international levels. (Source: UNDRR Glossary - https://www.undrr.org/terminology)" ;
    rdfs:subClassOf <http://knowwheregraph/ontology/dmdo/Event> .

<http://knowwheregraph/ontology/dpo/Vulnerability> a owl:Class ;
    rdfs:label "Vulnerability" ;
    rdfs:comment "The conditions determined by physical, social, economic and environmental factors or processes which increase the susceptibility of an individual, a community, assets or systems to the impacts of hazards. (Source: UNDRR Glossary - https://www.undrr.org/terminology)" ;
    rdfs:subClassOf sosa:ObservableProperty .

<https://mazu.cma/saudi#Indicator/heatwave_day_flag> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "heatwave_day_flag" ;
    rdfs:comment "热浪日标志" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS4>,
        <https://mazu.cma/saudi#DataSource/DS8>,
        <https://mazu.cma/saudi#Indicator/tmax_c>,
        <https://mazu.cma/saudi#Indicator/tmax_climatology_c> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/heatwave_duration_days>,
        <https://mazu.cma/saudi#Indicator/tmax_anomaly_c>,
        <https://mazu.cma/saudi#Indicator/tmax_c> ;
    saudi:effectiveDays 363 ;
    saudi:expression "tmax_c >= max(40 degC, tmax_climatology_c + 5 degC)" ;
    saudi:hasDAG "{\"op\": \"threshold\", \"left\": {\"op\": \"var\", \"name\": \"tmax_c\"}, \"condition\": \">=\", \"right\": {\"op\": \"max\", \"left\": 40, \"right\": {\"op\": \"add\", \"left\": {\"op\": \"var\", \"name\": \"tmax_climatology_c\"}, \"right\": 5}}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/ivt_convergence> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "ivt_convergence" ;
    qudt:unit qudt:KiloGM-PER-M2-SEC ;
    rdfs:comment "水汽输送辐合，正值代表水汽汇聚有利降水" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2>,
        <https://mazu.cma/saudi#Indicator/ivt_divergence> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/daily_precip_total>,
        <https://mazu.cma/saudi#Indicator/flash_flood_risk>,
        <https://mazu.cma/saudi#Indicator/ivt>,
        <https://mazu.cma/saudi#Indicator/ivt_divergence>,
        <https://mazu.cma/saudi#Indicator/pwat> ;
    saudi:effectiveDays 291 ;
    saudi:expression "-ivt_divergence" ;
    saudi:hasDAG "{\"op\": \"neg\", \"left\": {\"op\": \"var\", \"name\": \"ivt_divergence\"}}" ;
    saudi:totalDays 365 .

hip1:HC29 a owl:Class ;
    rdfs:label "Precipitation Related" ;
    rdfs:isDefinedBy "Source: UNDRR - https://www.undrr.org/publication/hazard-information-profiles-supplement-undrr-isc-hazard-definition-classification" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:MH ],
        hip1:HazardCluster .

ssn:hasProperty a owl:ObjectProperty .

ssn:isPropertyOf a owl:ObjectProperty .

<https://mazu.cma/saudi#Indicator/ds10_max_1h> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "ds10_max_1h" ;
    qudt:unit qudt:MilliM ;
    rdfs:comment "DS10 1小时最大降水，山洪短历时降水核心候选" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS10> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/daily_precip_total>,
        <https://mazu.cma/saudi#Indicator/ds10_max_30min>,
        <https://mazu.cma/saudi#Indicator/ds10_max_3h>,
        <https://mazu.cma/saudi#Indicator/flash_flood_risk> ;
    saudi:effectiveDays 273 ;
    saudi:expression "max_1h, 最近邻重采样" ;
    saudi:hasDAG "{\"op\": \"nearest_resample\", \"var\": \"ds10_max_1h_raw\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/flash_flood_risk> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "flash_flood_risk" ;
    rdfs:comment "山洪初筛分数(0-5)，可用条件阈值标志求和" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS10>,
        <https://mazu.cma/saudi#DataSource/DS2>,
        <https://mazu.cma/saudi#Indicator/cape>,
        <https://mazu.cma/saudi#Indicator/convective_precip_ratio>,
        <https://mazu.cma/saudi#Indicator/daily_precip_total>,
        <https://mazu.cma/saudi#Indicator/ds10_max_1h>,
        <https://mazu.cma/saudi#Indicator/wind10_speed> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/cape>,
        <https://mazu.cma/saudi#Indicator/daily_precip_total>,
        <https://mazu.cma/saudi#Indicator/ds10_max_1h>,
        <https://mazu.cma/saudi#Indicator/ivt_convergence>,
        <https://mazu.cma/saudi#Indicator/pwat> ;
    saudi:effectiveDays 365 ;
    saudi:expression "SUM of 5 threshold flags" ;
    saudi:hasDAG "{\"op\": \"sum_flags\", \"flags\": [{\"indicator\": \"daily_precip_total\", \"condition\": \">=\", \"value\": 10}, {\"indicator\": \"convective_precip_ratio\", \"condition\": \">=\", \"value\": 0.5}, {\"indicator\": \"cape\", \"condition\": \">=\", \"value\": 1000}, {\"indicator\": \"wind10_speed\", \"condition\": \">=\", \"value\": 10}, {\"indicator\": \"ds10_max_1h\", \"condition\": \">=\", \"value\": 10}]}" ;
    saudi:totalDays 365 .

