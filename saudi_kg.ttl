    saudi:effectiveDays 363 ;
    saudi:expression "ncpcp" ;
    saudi:hasDAG "{\"op\": \"var\", \"name\": \"ncpcp\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/daily_precip_climatology> a dpo:Intensity,
