            owl:someValuesFrom hip1:HC02 ],
        hip1:SpecificHazard ;
    hip1:identifier "BI0003" ;
    hip1:synonym "Locust outbreaks",
        "Locust plagues",
        "Locust upsurges" .

hip1:BI0004 a owl:Class,
        owl:NamedIndividual,
        hip1:BI0004 ;
    rdfs:label "Invasive Weeds" ;
