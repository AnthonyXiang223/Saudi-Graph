<https://mazu.cma/saudi#Indicator/wind850_speed> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "wind850_speed" ;
    qudt:unit qudt:M-PER-SEC ;
    rdfs:comment "850 hPa风速，低空急流和水汽输送" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/moisture_transport850>,
        <https://mazu.cma/saudi#Indicator/wind925_speed>,
        <https://mazu.cma/saudi#Indicator/wind_shear_850_200>,
        <https://mazu.cma/saudi#Indicator/wind_shear_850_300> ;
    saudi:effectiveDays 291 ;
    saudi:expression "sqrt(u850^2 + v850^2)" ;
    saudi:hasDAG "{\"op\": \"sqrt\", \"left\": {\"op\": \"add\", \"left\": {\"op\": \"sqr\", \"left\": {\"op\": \"var\", \"name\": \"u850\"}}, \"right\": {\"op\": \"sqr\", \"left\": {\"op\": \"var\", \"name\": \"v850\"}}}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/wind925_speed> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "wind925_speed" ;
    qudt:unit qudt:M-PER-SEC ;
