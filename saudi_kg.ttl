deo1:possiblyCauses a owl:ObjectProperty ;
    rdfs:label "possibly causes" ;
    owl:propertyChainAxiom ( deo1:hasPossiblyCausesRelation deo1:resultsIn ) .

<http://knowwheregraph/ontology/deo/Event> a owl:Class ;
    rdfs:label "Event" ;
    skos:description "This generic concept denotes any disaster-related occurrences (hazard, disaster, impact) with observable properties (e.g., intensity, magnitude, extent) that can be measured. In that sense this concept can also be mentioned as a subclass of sosa:FeatureOfInterest from the SOSA ontology, which denotes any feature that can be observed based on a set of its attributes." .

<http://knowwheregraph/ontology/dmdo/HazardType> a owl:Class ;
    rdfs:label "Hazard Type" ;
    rdfs:comment "This concept refers to the hazard theme or the ultimate feature of interest in SOSA terminology." .

<http://knowwheregraph/ontology/dpo/Severity> a owl:Class ;
    rdfs:label "Severity" ;
    rdfs:subClassOf sosa:ObservableProperty .

prov:hadPrimarySource a owl:ObjectProperty .

<https://mazu.cma/saudi#Indicator/apparent_temp_c> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "apparent_temp_c" ;
    qudt:unit qudt:DegreeCelsius ;
    rdfs:comment "体感温度" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/heat_index_c>,
        <https://mazu.cma/saudi#Indicator/t2m_c> ;
    saudi:effectiveDays 362 ;
    saudi:expression "aptmp - 273.15" ;
    saudi:hasDAG "{\"op\": \"sub\", \"left\": {\"op\": \"var\", \"name\": \"aptmp\"}, \"right\": 273.15}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/best_lifted_index> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "best_lifted_index" ;
    qudt:unit qudt:Kelvin ;
    rdfs:comment "最佳四层抬升指数，越低越有利于强对流" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/cape>,
        <https://mazu.cma/saudi#Indicator/surface_lifted_index> ;
    saudi:effectiveDays 292 ;
    saudi:expression "若源变量带额外层维度，先对非水平维取最小值" ;
    saudi:hasDAG "{\"op\": \"min_over_dim\", \"var\": \"best_lifted_index_raw\", \"dim\": \"pressureFromGroundLayer\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/bowen_ratio> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "bowen_ratio" ;
    qudt:unit qudt:UNITLESS ;
    rdfs:comment "日 Bowen 比，感热相对潜热" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/heat_stress_index>,
        <https://mazu.cma/saudi#Indicator/vpd_kpa> ;
    saudi:effectiveDays 364 ;
    saudi:expression "avg_ishf / avg_slhtf" ;
    saudi:hasDAG "{\"op\": \"div\", \"left\": {\"op\": \"var\", \"name\": \"avg_ishf\"}, \"right\": {\"op\": \"var\", \"name\": \"avg_slhtf\"}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/daily_precip_anomaly> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "daily_precip_anomaly" ;
    qudt:unit qudt:MilliM ;
    rdfs:comment "日降水距平，正值表示高于1991-2020同日站点气候态" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2>,
        <https://mazu.cma/saudi#DataSource/DS8>,
        <https://mazu.cma/saudi#Indicator/daily_precip_climatology>,
        <https://mazu.cma/saudi#Indicator/daily_precip_total> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/daily_precip_anomaly_ratio>,
        <https://mazu.cma/saudi#Indicator/daily_precip_total> ;
    saudi:effectiveDays 363 ;
    saudi:expression "daily_precip_total - daily_precip_climatology" ;
    saudi:hasDAG "{\"op\": \"sub\", \"left\": {\"op\": \"var\", \"name\": \"daily_precip_total\"}, \"right\": {\"op\": \"var\", \"name\": \"daily_precip_climatology\"}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/daily_precip_anomaly_ratio> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "daily_precip_anomaly_ratio" ;
    qudt:unit qudt:UNITLESS ;
    rdfs:comment "日降水距平率，干旱区分母很小会放大" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2>,
        <https://mazu.cma/saudi#DataSource/DS8>,
        <https://mazu.cma/saudi#Indicator/daily_precip_climatology>,
        <https://mazu.cma/saudi#Indicator/daily_precip_total> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/daily_precip_anomaly> ;
    saudi:effectiveDays 272 ;
    saudi:expression "(daily_precip_total - climatology) / climatology" ;
    saudi:hasDAG "{\"op\": \"div\", \"left\": {\"op\": \"sub\", \"left\": {\"op\": \"var\", \"name\": \"daily_precip_total\"}, \"right\": {\"op\": \"var\", \"name\": \"daily_precip_climatology\"}}, \"right\": {\"op\": \"var\", \"name\": \"daily_precip_climatology\"}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/ds10_ds2_precip_ratio> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "ds10_ds2_precip_ratio" ;
    qudt:unit qudt:UNITLESS ;
    rdfs:comment "DS10/DS2日降水比值，识别两套降水估计偏差" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS10>,
        <https://mazu.cma/saudi#DataSource/DS2>,
        <https://mazu.cma/saudi#Indicator/daily_precip_total>,
        <https://mazu.cma/saudi#Indicator/ds10_daily_total> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/ds10_ds2_precip_diff> ;
    saudi:effectiveDays 270 ;
    saudi:expression "ds10_daily_total / daily_precip_total" ;
    saudi:hasDAG "{\"op\": \"div\", \"left\": {\"op\": \"var\", \"name\": \"ds10_daily_total\"}, \"right\": {\"op\": \"var\", \"name\": \"daily_precip_total\"}}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/geopotential_height500> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "geopotential_height500" ;
    qudt:unit qudt:M ;
    rdfs:comment "500 hPa位势高度，中层环流和脊槽背景" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/omega500>,
        <https://mazu.cma/saudi#Indicator/surface_pressure> ;
    saudi:effectiveDays 293 ;
