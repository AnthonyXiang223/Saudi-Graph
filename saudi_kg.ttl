    rdfs:label "Intergovernmental Panel on Climate Change" .

hip1:organization.ipcs a owl:NamedIndividual,
        hip1:Organization ;
    rdfs:label "International Programme on Chemical Safety" .

hip1:organization.unccd a owl:NamedIndividual,
        hip1:Organization ;
    rdfs:label "United Nations Convention to Combat Desertification" .

hip1:organization.unece a owl:NamedIndividual,
        hip1:Organization ;
