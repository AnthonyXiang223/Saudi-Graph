<https://mazu.cma/saudi#Indicator/qmin_2m> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "qmin_2m" ;
    qudt:unit qudt:KiloGM-PER-KiloGM ;
    rdfs:comment "日最小2米比湿，干燥背景下限" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS4> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/qmax_2m>,
        <https://mazu.cma/saudi#Indicator/sh2m> ;
    saudi:effectiveDays 363 ;
    saudi:expression "qmin" ;
    saudi:hasDAG "{\"op\": \"var\", \"name\": \"qmin\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/relative_vorticity850> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "relative_vorticity850" ;
    qudt:unit qudt:PER-SEC ;
    rdfs:comment "850 hPa相对涡度，低层旋转和天气扰动" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/absolute_vorticity850>,
        <https://mazu.cma/saudi#Indicator/divergence850> ;
    saudi:effectiveDays 291 ;
    saudi:expression "dv/dx - du/dy" ;
    saudi:hasDAG "{\"op\": \"spatial_vorticity\", \"u_var\": \"u850\", \"v_var\": \"v850\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/surface_pressure> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "surface_pressure" ;
    qudt:unit qudt:Pascal ;
    rdfs:comment "地面气压" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS2> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/geopotential_height500>,
        <https://mazu.cma/saudi#Indicator/wind10_speed> ;
    saudi:effectiveDays 292 ;
    saudi:expression "sp" ;
    saudi:hasDAG "{\"op\": \"var\", \"name\": \"sp\"}" ;
    saudi:totalDays 365 .

<https://mazu.cma/saudi#Indicator/t2m_climatology_c> a dpo:Intensity,
        sosa:ObservableProperty ;
    rdfs:label "t2m_climatology_c" ;
    qudt:unit qudt:DegreeCelsius ;
    rdfs:comment "1991-2020日平均气温气候态(DS8站点最近邻映射)" ;
    prov:wasDerivedFrom <https://mazu.cma/saudi#DataSource/DS8> ;
    saudi:coOccursWith <https://mazu.cma/saudi#Indicator/t2m_anomaly_c>,
        <https://mazu.cma/saudi#Indicator/t2m_climatology_station_distance_km> ;
    saudi:effectiveDays 364 ;
    saudi:expression "DS8 TAVG/MDAY 最近站逐日 normal" ;
    saudi:hasDAG "{\"op\": \"ds8_lookup\", \"element\": \"TAVG\", \"stat\": \"MDAY\"}" ;
    saudi:totalDays 365 .

hip1:HC01 a owl:Class ;
    rdfs:label "Fisheries And Aquaculture",
        "Fisheries and Aquaculture" ;
    rdfs:isDefinedBy "" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:CH ],
        hip1:HazardCluster .

hip1:HC02 a owl:Class ;
    rdfs:label "Insect Infestation" ;
    rdfs:isDefinedBy "" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hip1:broader ;
            owl:someValuesFrom hip1:BI ],
        hip1:HazardCluster .

