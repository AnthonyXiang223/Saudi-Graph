          "value": 10,
          "weight": 0.141
        },
        {
          "indicator": "ivt_convergence",
          "op": ">",
          "value": 0,
          "weight": 0.08
        }
      ],
      "connectivity": 4,
      "min_cluster_size": 3,
      "severity": [
        {
          "label": "low",
          "range": [
            0.0,
            0.3
          ]
        },
        {
          "label": "medium",
          "range": [
            0.3,
            0.6
          ]
        },
        {
          "label": "high",
          "range": [
            0.6,
            0.8
