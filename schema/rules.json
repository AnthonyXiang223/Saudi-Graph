{
  "meta": {
    "description": "Business rules for extreme event early warning detection – Saudi Arabia knowledge graph",
    "version": "1.0.0",
    "last_updated": "2026-07-09",
    "weighted_logic": "Each condition contributes its weight (0-1) when satisfied. Total score = sum of satisfied weights. Normalised to [0,1] by dividing by the sum of all available weights (accounting for fallback drops).",
    "weight_source": "logistic_regression_L1_learned_from_365_days_normalized",
    "note": "标签: 报告已知极端日期vs静默日期. L1逻辑回归学习权重, primary gate保持0.30不变, 其余按学习比例归一化到0.70总池."
  },
  "rules": [
    {
      "id": "flash_flood_weighted",
      "hazard_type": "flash_flood",
      "conditions": [
        {
          "indicator": "flash_flood_risk",
          "op": ">=",
          "value": 3,
          "weight": 0.052,
          "primary": true
        },
        {
          "indicator": "daily_precip_total",
          "op": ">=",
          "value": 10,
          "weight": 0.166
        },
        {
          "indicator": "cape",
          "op": ">=",
          "value": 1000,
          "weight": 0.313
        },
        {
          "indicator": "ds10_max_1h",
