        },
        {
          "label": "extreme",
          "range": [
            0.8,
            1.0
          ]
        }
      ],
      "fallback": {
        "strategy": "drop_condition",
        "missing_indicator": "ds10_max_1h",
        "confidence_penalty": 0.15,
        "description": "ds10_max_1h frequently unavailable in Q4 (Oct–Dec). When missing, drop the condition and subtract 0.15 from the normalised score. Re-normalise over remaining weights."
      }
    },
